@model ProductSearchInput

@{
    ViewBag.Title = "Quản lý Mặt hàng";
    @* ViewBag.UserName = "Gemini"; *@
}
@section PageToolBar {
    <a href="~/Product/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}


@* // Trong View (Index.cshtml)
<p>Chào @ViewBag.UserName</p>  // Kết quả: Chào Gemini
<p>Chào @ViewBag.username</p> *@
<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" method="get" action="~/Product/Search" data-target="searchResult" onsubmit="paginationSearch(event, this, 1)">
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">Loại hàng</label>
                    <select class="form-select" name="CategoryID">
                        <option value="0">-- Tất cả --</option>
                        @foreach (var item in ViewBag.Categories as List<Category>)
                        {
                            if (item.CategoryID == Model.CategoryID)
                            {
                                <option value="@item.CategoryID" selected>@item.CategoryName</option>
                            }
                            else
                            {
                                <option value="@item.CategoryID">@item.CategoryName</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Nhà cung cấp</label>
                    <select class="form-select" name="SupplierID">
                        <option value="0">-- Tất cả --</option>
                        @foreach (var item in ViewBag.Suppliers as List<Supplier>)
                        {
                            if (item.SupplierID == Model.SupplierID)
                            {
                                <option value="@item.SupplierID" selected>@item.SupplierName</option>
                            }
                            else
                            {
                                <option value="@item.SupplierID">@item.SupplierName</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Khoảng giá</label>
                    <div class="input-group">
                        <input type="text"
                            name="MinPrice" 
                            id="MinPrice"
                            class="form-control money-input"
                            value="@(Model.MinPrice > 0 ? Model.MinPrice.ToString("N0") : "")"
                            placeholder="Từ" />
                        <span class="input-group-text">-</span>
                        <input type="text"
                            name="MaxPrice"
                            id="MaxPrice"
                            class="form-control money-input"
                            value="@(Model.MaxPrice > 0 ? Model.MaxPrice.ToString("N0") : "")"
                            placeholder="Đến" />
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Tên mặt hàng</label>
                    <div class="input-group">
                        <input type="text"
                               name="searchValue"
                               class="form-control"
                               value="@Model.SearchValue"
                               placeholder="Tên mặt hàng..." autofocus />
                        <button class="btn btn-info d-flex align-items-center">
                            <i class="bi bi-search me-1"></i>
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div id="searchResult">
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            paginationSearch(null, document.getElementById("formSearch"), @Model.Page);
        });
    </script>
}