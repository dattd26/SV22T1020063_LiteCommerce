@{
    ViewBag.Title = "Xác nhận xóa mặt hàng";
}

<div class="row">
    <div class="col-md-8 mx-auto w-100">
        <div class="card card-outline card-danger shadow-sm">
            <div class="card-header">
                <h3 class="card-title fw-bold text-danger">
                    <i class="bi bi-exclamation-octagon-fill me-2"></i>
                    Bạn có chắc chắn muốn xóa mặt hàng này?
                </h3>
            </div>

            <form action="/Product/Delete" method="post">
                <input type="hidden" name="ProductID" value="1" />

                <div class="card-body">
                    <div class="alert alert-danger border-danger d-flex align-items-center">
                        <i class="bi bi-info-circle-fill fs-4 me-3"></i>
                        <div>
                            <strong>Cảnh báo:</strong> Hành động này không thể hoàn tác.
                            Nếu mặt hàng này đã có trong các đơn hàng cũ, hệ thống có thể ngăn chặn việc xóa để đảm bảo tính toàn vẹn dữ liệu.
                        </div>
                    </div>

                    <div class="row bg-light p-4 rounded border mt-3">
                        <div class="col-sm-4 text-center mb-3">
                            <img src="~/images/products/iphone15.jpg"
                                 class="img-thumbnail rounded shadow-sm"
                                 style="width: 100%; max-width: 180px; height: 180px; object-fit: cover;"
                                 alt="Product Thumbnail">
                            <div class="mt-2">
                                <span class="badge text-bg-secondary">Mã SP: #P001</span>
                            </div>
                        </div>

                        <div class="col-sm-8">
                            <h4 class="fw-bold">iPhone 15 Pro Max 256GB</h4>
                            <hr class="my-2">

                            <div class="row mb-2">
                                <div class="col-sm-4 text-muted">Loại hàng:</div>
                                <div class="col-sm-8 fw-semibold">Điện thoại</div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-sm-4 text-muted">Nhà cung cấp:</div>
                                <div class="col-sm-8 fw-semibold text-primary">Apple Inc.</div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-sm-4 text-muted">Đơn vị:</div>
                                <div class="col-sm-8">Chiếc</div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-sm-4 text-muted">Giá niêm yết:</div>
                                <div class="col-sm-8 text-danger fw-bold">32.990.000 ₫</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer d-flex justify-content-end gap-2 bg-transparent border-top-0">
                    <button type="submit" class="btn btn-danger px-4">
                        <i class="bi bi-trash-fill me-1"></i> Xác nhận xóa vĩnh viễn
                    </button>
                    <a href="/Product" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-x-circle me-1"></i> Hủy bỏ
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>