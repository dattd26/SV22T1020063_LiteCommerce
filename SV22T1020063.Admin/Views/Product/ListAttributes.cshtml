@{
    ViewBag.Title = "Thuộc tính mặt hàng";
}

<div class="container-fluid">
    <div class="card mb-4 border-left-primary shadow-sm">
        <div class="card-body">
            <div class="d-flex align-items-center">
                <img src="~/images/products/iphone15.jpg" class="rounded border me-3"
                     style="width: 60px; height: 60px; object-fit: cover;" alt="Product">
                <div>
                    <h5 class="mb-0 fw-bold">iPhone 15 Pro Max 256GB</h5>
                    <small class="text-muted">Quản lý các thông số kỹ thuật và thuộc tính chi tiết</small>
                </div>
                <div class="ms-auto">
                    <a href="/Product/Detail/1" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-arrow-left"></i> Quay lại chi tiết SP
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-white d-flex align-items-center justify-content-between py-3">
            <h6 class="m-0 font-weight-bold text-primary"><i class="bi bi-list-ul me-2"></i>Danh sách thuộc tính</h6>
            <div class="ms-auto" >
                <a href="/Product/CreateAttribute/1" class="btn btn-success btn-sm">
                    <i class="bi bi-plus-circle me-1"></i> Thêm thuộc tính mới
                </a>
            </div>

            
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-bordered mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 80px" class="text-center">Thứ tự</th>
                            <th style="width: 250px">Tên thuộc tính</th>
                            <th>Giá trị</th>
                            <th style="width: 120px" class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="text-center fw-bold">1</td>
                            <td class="fw-semibold text-dark">Màn hình</td>
                            <td>6.7 inch, LTPO Super Retina XDR OLED, 120Hz</td>
                            <td class="text-center">
                                <div class="btn-group">
                                    <a href="/Product/EditAttribute/101" class="btn btn-outline-primary btn-sm" title="Sửa">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a href="/Product/DeleteAttribute/101" class="btn btn-outline-danger btn-sm" title="Xóa">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td class="text-center fw-bold">2</td>
                            <td class="fw-semibold text-dark">Chipset</td>
                            <td>Apple A17 Pro (3 nm)</td>
                            <td class="text-center">
                                <div class="btn-group">
                                    <a href="/Product/EditAttribute/102" class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a href="/Product/DeleteAttribute/102" class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td class="text-center fw-bold">3</td>
                            <td class="fw-semibold text-dark">Dung lượng Pin</td>
                            <td>4,441 mAh</td>
                            <td class="text-center">
                                <div class="btn-group">
                                    <a href="/Product/EditAttribute/103" class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a href="/Product/DeleteAttribute/103" class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white small text-muted">
            <i class="bi bi-info-circle me-1"></i> Các thuộc tính sẽ được hiển thị trên website theo <b>Thứ tự</b> đã thiết lập.
        </div>
    </div>
</div>