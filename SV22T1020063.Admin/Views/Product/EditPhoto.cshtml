@model ProductPhoto
@{
}
<div class="row justify-content-center">
    <div class="col-8">
        <div class="card card-primary card-outline">
            <div class="card-header p-2">
                <h6 class="card-title mb-0">@ViewBag.Title</h6>
            </div>
            <div class="card-body">
                <form action="~/Product/SavePhoto" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="PhotoID" />
                    <input type="hidden" asp-for="ProductID" />

                    <div class="mb-3">
                        <label class="form-label">Chọn ảnh cho mặt hàng</label>
                        <input type="hidden" asp-for="Photo" />
                        <input type="file" name="uploadPhoto" class="form-control" accept="image/*"
                               data-img-preview="imgPreview" onchange="previewImage(this)" />
                        <div class="mt-2 text-center">
                            <img id="imgPreview"
                                 src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                                 class="img-thumbnail" style="max-height: 160px;" />
                        </div>
                        <span asp-validation-for="Photo" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Mô tả ảnh</label>
                        <input type="text" class="form-control" asp-for="Description"
                               placeholder="Ví dụ: Ảnh mặt chính, Ảnh mặt sau..." />
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Thứ tự hiển thị</label>
                        <input type="number" class="form-control" asp-for="DisplayOrder" min="1" />
                        <span asp-validation-for="DisplayOrder" class="text-danger"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" id="IsHidden" asp-for="IsHidden" />
                                <label class="form-check-label" for="IsHidden">
                                    Ẩn ảnh (không hiển thị với khách hàng)
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3 text-end">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Lưu dữ liệu
                        </button>
                        <a href="~/Product/Edit/@Model.ProductID" class="btn btn-secondary">
                            <i class="bi bi-x-circle"></i> Hủy và quay lại
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
