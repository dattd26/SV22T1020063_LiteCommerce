@{
    ViewBag.Title = "Chi tiết mặt hàng";
}

<div class="container-fluid">
    <div class="card card-outline card-info shadow-sm">
        <div class="card-header">
            <h3 class="card-title fw-bold">Chi tiết mặt hàng</h3>
            <div class="card-tools">
                <a href="/Product/ListAttributes/1" class="btn btn-info btn-sm">
                    <i class="bi bi-gear-fill me-1"></i> Thuộc tính (Specs)
                </a>
                <a href="/Product/Edit/1" class="btn btn-warning btn-sm">
                    <i class="bi bi-pencil-square me-1"></i> Chỉnh sửa
                </a>
            </div>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4 text-center mb-4">
                    <div class="p-3 border rounded bg-light">
                        <img src="~/images/products/iphone15.jpg"
                             class="img-fluid rounded shadow-sm"
                             style="max-height: 400px; object-fit: contain;"
                             alt="Product Photo">
                    </div>
                    <div class="mt-3">
                        <span class="badge rounded-pill p-2 px-3 @(true ? "text-bg-success" : "text-bg-secondary")">
                            <i class="bi bi-check-circle me-1"></i> @(true ? "Đang kinh doanh" : "Ngừng kinh doanh")
                        </span>
                    </div>
                </div>

                <div class="col-md-8">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle">
                            <tbody>
                                <tr>
                                    <th style="width: 200px;" class="text-muted">Tên mặt hàng:</th>
                                    <td class="fw-bold fs-5">iPhone 15 Pro Max 256GB</td>
                                </tr>
                                <tr>
                                    <th class="text-muted">Loại hàng:</th>
                                    <td><span class="badge bg-info-subtle text-info border border-info-subtle">Điện thoại</span></td>
                                </tr>
                                <tr>
                                    <th class="text-muted">Nhà cung cấp:</th>
                                    <td><a href="/Supplier/Detail/1" class="text-decoration-none"><i class="bi bi-truck me-1"></i>Apple Inc.</a></td>
                                </tr>
                                <tr>
                                    <th class="text-muted">Đơn vị tính:</th>
                                    <td>Chiếc</td>
                                </tr>
                                <tr>
                                    <th class="text-muted">Giá niêm yết:</th>
                                    <td class="text-danger fw-bold fs-4">32.990.000 ₫</td>
                                </tr>
                                <tr>
                                    <th class="text-muted">Mô tả chi tiết:</th>
                                    <td>
                                        <div class="p-3 bg-light rounded border shadow-sm">
                                            Chip A17 Pro siêu mạnh mẽ, Camera 48MP zoom quang 5x, Khung Titanium bền bỉ, Cổng sạc USB-C thế hệ mới...
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-footer bg-transparent border-top">
            <div class="d-flex justify-content-between">
                <a href="/Product" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Quay lại danh sách
                </a>
                <a href="/Product/Delete/1" class="btn btn-outline-danger">
                    <i class="bi bi-arrow-left"></i> Xóa mặt hàng này
                </a>

            </div>
        </div>
    </div>
</div>