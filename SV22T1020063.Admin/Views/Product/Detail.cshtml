@model Product
@{
    ViewBag.Title = "Chi tiết mặt hàng";
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-outline card-info shadow-sm">
            <div class="card-header">
                <h3 class="card-title fw-bold">Chi tiết mặt hàng</h3>
                <div class="card-tools">
                    <a href="~/Product/Edit/@Model.ProductID" class="btn btn-warning btn-sm">
                        <i class="bi bi-pencil-square me-1"></i> Chỉnh sửa
                    </a>
                    <a href="~/Product/Delete/@Model.ProductID" class="btn btn-danger btn-sm">
                        <i class="bi bi-trash me-1"></i> Xóa
                    </a>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 text-center mb-4">
                        <div class="p-3 border rounded bg-light">
                            <img src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                                 class="img-fluid rounded shadow-sm"
                                 style="max-height: 400px; object-fit: contain;"
                                 alt="Product Photo">
                        </div>
                        <div class="mt-3">
                            <span class="badge rounded-pill p-2 px-3 @(Model.IsSelling ? "bg-success" : "bg-secondary")">
                                <i class="bi bi-check-circle me-1"></i> @(Model.IsSelling ? "Đang kinh doanh" : "Ngừng kinh doanh")
                            </span>
                        </div>
                    </div>

                    <div class="col-md-8">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover align-middle">
                                <tbody>
                                    <tr>
                                        <th style="width: 200px;" class="text-muted">Tên mặt hàng:</th>
                                        <td class="fw-bold fs-5">@Model.ProductName</td>
                                    </tr>
                                    <tr>
                                        <th class="text-muted">Đơn vị tính:</th>
                                        <td>@Model.Unit</td>
                                    </tr>
                                    <tr>
                                        <th class="text-muted">Giá niêm yết:</th>
                                        <td class="text-danger fw-bold fs-4">@Model.Price.ToString("N0") ₫</td>
                                    </tr>
                                    <tr>
                                        <th class="text-muted">Mô tả chi tiết:</th>
                                        <td>
                                            <div class="p-3 bg-light rounded border shadow-sm" style="white-space: pre-wrap;">
                                                @Model.ProductDescription
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-top">
                <div class="d-flex justify-content-between">
                    <a href="~/Product" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại danh sách
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>