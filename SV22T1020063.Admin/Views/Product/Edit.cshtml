@model Product
@{
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>

    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-box-seam me-2"></i>
                    Thông tin mặt hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" action="~/Product/Save" enctype="multipart/form-data">
                    <input type="hidden" asp-for="ProductID" />

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Tên mặt hàng</label>
                        <div class="col-sm-9">
                            <input type="text" asp-for="ProductName" class="form-control"
                                   placeholder="Nhập tên mặt hàng" autofocus />
                            <span asp-validation-for="ProductName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Loại hàng</label>
                        <div class="col-sm-3">
                            <select class="form-select" asp-for="CategoryID">
                                <option value="0">-- Chọn loại hàng --</option>
                                @foreach (var item in ViewBag.Categories)
                                {
                                    <option value="@item.CategoryID">@item.CategoryName</option>
                                }
                            </select>
                            <span asp-validation-for="CategoryID" class="text-danger"></span>
                        </div>

                        <label class="col-sm-2 col-form-label text-end">Nhà cung cấp</label>
                        <div class="col-sm-4">
                            <select class="form-select" asp-for="SupplierID">
                                <option value="0">-- Chọn nhà cung cấp --</option>
                                @foreach (var item in ViewBag.Suppliers)
                                {
                                    <option value="@item.SupplierID">@item.SupplierName</option>
                                }
                            </select>
                            <span asp-validation-for="SupplierID" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Đơn vị tính</label>
                        <div class="col-sm-3">
                            <input type="text" asp-for="Unit" class="form-control" placeholder="cái, hộp, kg..." />
                            <span asp-validation-for="Unit" class="text-danger"></span>
                        </div>

                        <label class="col-sm-2 col-form-label text-end">Giá</label>
                        <div class="col-sm-4">
                            <input type="text" asp-for="Price" class="form-control money-input" placeholder="Giá bán"
                                   min="0" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" id="IsSelling" asp-for="IsSelling" />
                                <label class="form-check-label" for="IsSelling">
                                    Đang bán
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Ảnh</label>
                        <div class="col-sm-9">
                            <input type="hidden" asp-for="Photo" />
                            <input type="file" name="uploadPhoto" class="form-control" accept="image/*"
                                   data-img-preview="imgPreview" onchange="previewImage(this)" />
                            <div class="mt-2">
                                <img id="imgPreview"
                                     src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "demo.png" : Model.Photo)"
                                     class="img-thumbnail" style="max-height: 160px;" />
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Mô tả</label>
                        <div class="col-sm-9">
                            <textarea class="form-control" asp-for="ProductDescription" rows="3"
                                      placeholder="Nhập mô tả mặt hàng"></textarea>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-9 offset-3">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        </div>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@if (Model.ProductID > 0)
{
    await Html.RenderPartialAsync("ListPhotos", ViewBag.Photos as IEnumerable<ProductPhoto>);
    await Html.RenderPartialAsync("ListAttributes", ViewBag.Attributes as IEnumerable<ProductAttribute>);
}