@{
    ViewBag.Title = "Truy cập bị từ chối";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow border-0 mt-5 bg-body-surface">
            <div class="card-body text-center py-5">
                <div class="mb-4">
                    <i class="bi bi-shield-lock-fill text-danger" style="font-size: 6rem; opacity: 0.82;"></i>
                </div>
                <h3 class="fw-bold mb-4">KHÔNG CÓ QUYỀN TRUY CẬP!</h3>
                <p class="text-muted mb-5 fs-5 px-4">
                    Tài khoản của bạn không có đủ quyền hạn để truy cập vào trang này hoặc thực hiện thao tác vừa rồi.
                    Vui lòng liên hệ với quản trị viên nếu bạn cho rằng đây là một sự nhầm lẫn.
                </p>
                <div class="d-flex flex-wrap justify-content-center gap-3">
                    <a href="~/" class="btn btn-primary btn-lg px-4 shadow-sm rounded-pill">
                        <i class="bi bi-house-door-fill me-2"></i> Quay về trang chủ
                    </a>
                    <a href="~/Account/Logout" class="btn btn-outline-danger btn-lg px-4 rounded-pill">
                        <i class="bi bi-box-arrow-right me-2"></i> Đăng nhập tài khoản khác
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>