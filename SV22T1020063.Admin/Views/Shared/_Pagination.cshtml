@using SV22T1020063.Models.Common
@model dynamic

@if (Model != null)
{
    var action = ViewData["ActionName"]?.ToString() ?? "Index";
    var controller = ViewData["ControllerName"]?.ToString() ?? ViewContext.RouteData.Values["controller"]?.ToString();
    var searchValue = ViewBag.SearchValue;

    <div class="card-footer d-flex flex-column flex-md-row justify-content-between align-items-center bg-white py-3">
        <div class="text-muted mb-3 mb-md-0">
            @if (Model.RowCount > 0)
            {
                <span>Hiển thị từ <strong>@((Model.Page - 1) * Model.PageSize + 1)</strong> đến <strong>@(Math.Min(Model.Page * Model.PageSize, Model.RowCount))</strong> trong tổng số <strong>@Model.RowCount</strong> bản ghi</span>
            }
            else
            {
                <span>Không tìm thấy dữ liệu nào phù hợp</span>
            }
        </div>

        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm mb-0 shadow-sm">
                @if (Model.PageCount > 1)
                {
                    <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                        <a class="page-link px-3" href="@Url.Action(action, controller, new { page = 1, searchValue = searchValue })" title="Trang đầu">
                            <i class="bi bi-chevron-bar-left"></i>
                        </a>
                    </li>
                    <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                        <a class="page-link px-3" href="@Url.Action(action, controller, new { page = Model.Page - 1, searchValue = searchValue })" title="Trang trước">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>

                    @foreach (var p in Model.GetDisplayPages())
                    {
                        if (p.IsEllipsis)
                        {
                            <li class="page-item disabled">
                                <span class="page-link">...</span>
                            </li>
                        }
                        else
                        {
                            <li class="page-item @(p.IsCurrent ? "active shadow-sm" : "")">
                                <a class="page-link px-3" href="@Url.Action(action, controller, new { page = p.Page, searchValue = searchValue })">@p.Page</a>
                            </li>
                        }
                    }

                    <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                        <a class="page-link px-3" href="@Url.Action(action, controller, new { page = Model.Page + 1, searchValue = searchValue })" title="Trang sau">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                    <li class="page-item @(Model.Page == Model.PageCount ? "disabled" : "")">
                        <a class="page-link px-3" href="@Url.Action(action, controller, new { page = Model.PageCount, searchValue = searchValue })" title="Trang cuối">
                            <i class="bi bi-chevron-bar-right"></i>
                        </a>
                    </li>
                }
            </ul>
        </nav>
    </div>
}
