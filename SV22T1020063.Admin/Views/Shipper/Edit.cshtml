<div class="row">
    <div class="col-md-8 mx-auto w-100">
        <div class="card card-outline card-success">
            <div class="card-header">
                <h3 class="card-title">@ViewBag.Title</h3>
            </div>

            <form action="/Shipper/Save" method="post">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-8 mb-3">
                            <label for="ShipperName" class="form-label fw-bold">Tên người giao hàng</label>
                            <input type="text" class="form-control" id="ShipperName" name="ShipperName"
                                   placeholder="Ví dụ: Giao hàng tiết kiệm, DHL, FedEx..." required>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label for="Status" class="form-label fw-bold">Trạng thái</label>
                            <select class="form-select" id="Status" name="Status">
                                <option value="active">Sẵn sàng</option>
                                <option value="busy">Đang bận</option>
                                <option value="inactive">Ngừng hoạt động</option>
                            </select>
                        </div>

                        <div class="col-md-12 mb-3">
                            <label for="Phone" class="form-label fw-bold">Điện thoại liên hệ</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                                <input type="tel" class="form-control" id="Phone" name="Phone"
                                       placeholder="Nhập số điện thoại hotline hoặc cá nhân..." required>
                            </div>
                        </div>

                        <div class="col-md-12 mb-3">
                            <label for="Description" class="form-label fw-bold">Ghi chú / Mô tả</label>
                            <textarea class="form-control" id="Description" name="Description" rows="3"
                                      placeholder="Thông tin thêm về khu vực hoạt động hoặc loại hình vận chuyển..."></textarea>
                        </div>
                    </div>
                </div>

                <div class="card-footer d-flex justify-content-end gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-1"></i> Lưu dữ liệu
                    </button>
                    <a href="/Shipper" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>