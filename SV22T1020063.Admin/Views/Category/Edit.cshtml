<div class="row">
    <div class="col-md-8 mx-auto w-100">
        <div class="card card-outline card-primary">
            <div class="card-header">
                <h3 class="card-title">@ViewBag.Title</h3>
            </div>

            <form action="/Category/Save" method="post">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label for="CategoryName" class="form-label fw-bold">Tên loại hàng</label>
                            <input type="text" class="form-control" id="CategoryName" name="CategoryName"
                                   placeholder="Ví dụ: Điện tử, Quần áo, Thực phẩm" required>
                        </div>

                        <div class="col-md-12 mb-3">
                            <label for="Description" class="form-label fw-bold">Mô tả</label>
                            <textarea class="form-control" id="Description" name="Description" rows="5"
                                      placeholder="Nhập mô tả chi tiết về loại hàng..."></textarea>
                        </div>
                    </div>
                </div>

                <div class="card-footer d-flex justify-content-end gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-1"></i> Lưu dữ liệu
                    </button>
                    <a href="/Category" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>