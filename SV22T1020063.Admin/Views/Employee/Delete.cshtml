@{
    ViewBag.Title = "Xác nhận xóa nhân viên";
}

<div class="row">
    <div class="col-md-8 mx-auto w-100">
        <div class="card card-outline card-danger">
            <div class="card-header">
                <h3 class="card-title text-danger fw-bold">
                    <i class="bi bi-person-x-fill me-2"></i>
                    Cảnh báo: Bạn có chắc chắn muốn xóa nhân viên này?
                </h3>
            </div>

            <form action="/Employee/Delete" method="post">
                <input type="hidden" name="EmployeeID" value="1" />

                <div class="card-body">
                    <div class="alert alert-warning border-warning">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>Lưu ý:</strong> Dữ liệu liên quan đến doanh số, đơn hàng hoặc lịch sử xử lý của nhân viên này có thể bị ảnh hưởng. Hãy cân nhắc chuyển trạng thái sang <b>"Đã nghỉ việc"</b> thay vì xóa vĩnh viễn.
                    </div>

                    <div class="row bg-light p-4 rounded border">
                        <div class="col-sm-3 text-center mb-3">
                            <img src="~/images/employees/user1.jpg"
                                 class="img-thumbnail rounded-circle"
                                 style="width: 120px; height: 120px; object-fit: cover;"
                                 alt="Avatar">
                            <div class="mt-2">
                                <span class="badge text-bg-success">Đang làm việc</span>
                            </div>
                        </div>

                        <div class="col-sm-9">
                            <div class="row">
                                <div class="col-sm-4 fw-bold">Họ và tên:</div>
                                <div class="col-sm-8 mb-2">Nguyễn Văn An</div>

                                <div class="col-sm-4 fw-bold">Ngày sinh:</div>
                                <div class="col-sm-8 mb-2">15/03/1990</div>

                                <div class="col-sm-4 fw-bold">Vai trò:</div>
                                <div class="col-sm-8 mb-2 text-primary fw-bold">Quản trị viên, Thủ kho</div>

                                <hr class="my-2">

                                <div class="col-sm-4 fw-bold">Điện thoại:</div>
                                <div class="col-sm-8 mb-2">0912 345 678</div>

                                <div class="col-sm-4 fw-bold">Email:</div>
                                <div class="col-sm-8 mb-2">an.nv@company.com</div>

                                <div class="col-sm-4 fw-bold">Địa chỉ:</div>
                                <div class="col-sm-8">123 Đường Láng, Đống Đa, Hà Nội</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer d-flex justify-content-end gap-2">
                    <button type="submit" class="btn btn-danger px-4">
                        <i class="bi bi-trash me-1"></i> Xác nhận xóa vĩnh viễn
                    </button>
                    <a href="/Employee" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-1"></i> Bỏ qua
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>