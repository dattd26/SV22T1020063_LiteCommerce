@using SV22T1020063.Models.Common
@using SV22T1020063.Models.Partner
@model PagedResult<Shipper>
@{
    Layout = null;
    int orderID = ViewBag.OrderID;
}
<div class="modal-header text-bg-primary">
    <h5 class="modal-title">
        <i class="bi bi-truck me-2"></i> Chuyển đơn hàng cho người giao hàng
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">
    <!-- Form tìm kiếm vận chuyển -->
    <form id="formSearchShipper" 
          action="~/Order/SearchShipper/@orderID" 
          method="get" 
          data-target="shipperListContainer"
          onsubmit="paginationSearch(event, this, 1)">
        <div class="input-group mb-3">
            <span class="input-group-text bg-white">
                <i class="bi bi-search"></i>
            </span>
            <input type="text" name="searchValue" class="form-control" 
                   placeholder="Nhập tên hoặc số điện thoại để tìm đơn vị vận chuyển..." 
                   autofocus>
            <button class="btn btn-primary px-3" type="submit">
                Tìm kiếm
            </button>
        </div>
    </form>

    <!-- Container kết quả tìm kiếm (Ban đầu hiển thị danh sách tất cả) -->
    <div id="shipperListContainer" class="border rounded bg-light overflow-hidden">
        @await Html.PartialAsync("SearchShipper", Model)
    </div>
</div>

<div class="modal-footer bg-light shadow-sm">
    <button type="submit" form="formShipping" class="btn btn-primary px-4">
        <i class="bi bi-check2-circle me-1"></i> Bắt đầu vận chuyển
    </button>
    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
        Quay lại
    </button>
</div>

<style>
    /* Premium touch: Subtle hover highlights */
    #shipperListContainer tr:hover {
        background-color: #f8fbff !important;
    }
    
    /* Smooth transition for modal content loading */
    #shipperListContainer {
        transition: all 0.3s ease;
    }
</style>