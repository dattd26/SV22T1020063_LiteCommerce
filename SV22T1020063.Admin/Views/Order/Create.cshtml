@model ProductSearchInput
@{
    ViewBag.Title = "Lập đơn hàng";
}
<div class="row">
    <!-- Tìm kiếm & chọn mặt hàng -->
    <div class="col-md-4">
        <div class="card card-outline card-primary shadow-sm h-100">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-search text-primary"></i>
                    Lựa chọn hàng cần bán
                </h5>
            </div>

            <div class="card-body">
                <!-- Search -->
                <form id="formSearch" action="@Url.Action("SearchProduct", "Order")" method="get" class="mb-3">
                    <div class="input-group">
                        <input class="form-control"
                               name="SearchValue"
                               value="@Model.SearchValue"
                               placeholder="Nhập tên mặt hàng cần tìm" autofocus />
                        <button class="btn btn-primary" type="submit">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>

                <!-- Danh sách mặt hàng -->
                <div id="search-result">

                    <div class="text-center py-4">
                        <div class="spinner-border text-primary spinner-border-sm" role="status">
                            <span class="visually-hidden">Đang tải...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Giỏ hàng và thông tin khách hàng -->
    <div class="col-md-8">
        <!-- Giỏ hàng -->
        <div class="card card-outline card-success shadow-sm mb-4">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-cart text-success"></i>
                    Danh sách mặt hàng đã chọn
                </h5>
            </div>

            <div class="card-body p-0">
                <div id="cart-container" class="table-responsive">
                    <div class="p-4 text-center">
                        <div class="spinner-border text-success spinner-border-sm" role="status">
                            <span class="visually-hidden">Đang tải...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Thông tin khách hàng và nơi giao hàng -->
        <div class="card card-outline card-info shadow-sm">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-person text-info"></i>
                    Thông tin khách hàng & nơi giao hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formOrder" method="post" action="~/Order/Init">
                    <div class="row mb-3">
                        <label class="col-md-3 col-form-label fw-bold">Khách hàng</label>
                        <div class="col-md-9">
                            <select class="form-select select2" name="CustomerID" asp-items="await SelectListHelper.CustomersAsync()">

                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-md-3 col-form-label fw-bold">Tỉnh/thành giao hàng</label>
                        <div class="col-md-9">
                            <select class="form-select select2" name="DeliveryProvince">
                                @foreach (var item in await SelectListHelper.ProvincesAsync())
                                {
                                    <option value="@item.Value">@item.Text</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-md-3 col-form-label fw-bold">Địa chỉ nhận hàng</label>
                        <div class="col-md-9">
                            <textarea class="form-control" name="DeliveryAddress" rows="2" placeholder="Nhập địa chỉ nhận hàng"></textarea>
                        </div>
                    </div>

                    <div class="text-end border-top pt-3">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-circle me-1"></i>
                            Xác nhận lập đơn hàng
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function addCartItem(productId, quantity, price) {
            const url = '/Order/AddCartItem';

            // Tạo dữ liệu gửi đi (khớp với tên tham số trong hàm C#)
            const formData = new FormData();
            formData.append('productID', productId);
            formData.append('quantity', quantity);
            formData.append('price', price);

            try {
                const response = await fetch(url, {
                    method: 'POST',
                    body: formData
                });

                if (!response.ok) {
                    throw new Error('Lỗi mạng hoặc server không phản hồi');
                }

                const result = await response.json();

                if (result.status === 1 || result.Status === 1) { // Kiểm tra key trả về từ ApiResult
                    alert(result.message || result.Message);
                    
                    // Gọi hàm hiển thị giỏ hàng khi thành công
                    if (typeof showCart === 'function') {
                        showCart();
                    }
                } else {
                    alert('Thông báo: ' + (result.message || result.Message));
                }
            } catch (error) {
                console.error('Đã xảy ra lỗi:', error);
                alert('Không thể kết nối đến máy chủ');
            }
        }
        /**
         * Tìm kiếm mặt hàng (phân trang)
         */
        function doSearch(page) {
            const form = document.getElementById("formSearch");
            const container = document.getElementById("search-result");
            if (!form || !container) return;

            const url = form.getAttribute("action");
            const formData = new FormData(form);
            formData.append("Page", page);

            const params = new URLSearchParams(formData).toString();
            const fetchUrl = url + (url.indexOf("?") > -1 ? "&" : "?") + params;

            fetch(fetchUrl)
                .then(res => res.text())
                .then(html => {
                    container.innerHTML = html;
                })
                .catch(err => {
                    console.error("Search error:", err);
                    alert("Không thể tải danh sách mặt hàng.");
                });
        }

        /**
         * Hiển thị nội dung giỏ hàng
         */
        function showCart() {
            const container = document.getElementById("cart-container");
            if (!container) return;

            fetch("/Order/ShowCart")
                .then(res => res.text())
                .then(html => {
                    container.innerHTML = html;
                })
                .catch(err => console.error("Cart load error:", err));
        }
        async function editCartItem(productId, quantity, salePrice) {
            const url = '/Order/EditCartItem';

            // Tạo dữ liệu gửi đi (khớp với tên tham số trong hàm C#)
            const formData = new FormData();
            formData.append('id', productId);
            formData.append('quantity', quantity);
            formData.append('salePrice', salePrice);

            try {
                const response = await fetch(url, {
                    method: 'POST',
                    body: formData
                });

                if (!response.ok) {
                    throw new Error('Lỗi mạng hoặc server không phản hồi');
                }

                const result = await response.json();

                if (result.code === 1) { 
                    
                    showCart();
                } else {
                    alert('Thông báo thất bại: ' + result.message);
                }
            } catch (error) {
                console.error('Đã xảy ra lỗi:', error);
                alert('Không thể kết nối đến máy chủ');
            }
        }
        async function removeCartItem(productId) {
            const url = '/Order/DeleteCartItem';

            // Tạo dữ liệu gửi đi (khớp với tên tham số trong hàm C#)
            const formData = new FormData();
            formData.append('id', productId);

            try {
                const response = await fetch(url, {
                    method: 'POST',
                    body: formData
                });

                if (!response.ok) {
                    throw new Error('Lỗi mạng hoặc server không phản hồi');
                }

                const result = await response.json();

                if (result.code === 1) {

                    showCart();
                } else {
                    alert('Thông báo thất bại: ' + result.message);
                }
            } catch (error) {
                console.error('Đã xảy ra lỗi:', error);
                alert('Không thể kết nối đến máy chủ');
            }
        }
        async function addCartItem(productId, quantity, price) {
            const url = '/Order/AddCartItem';

            // Tạo dữ liệu gửi đi (khớp với tên tham số trong hàm C#)
            const formData = new FormData();
            formData.append('productID', productId);
            formData.append('quantity', quantity);
            formData.append('price', price);

            try {
                const response = await fetch(url, {
                    method: 'POST',
                    body: formData
                });

                if (!response.ok) {
                    throw new Error('Lỗi mạng hoặc server không phản hồi');
                }

                const result = await response.json();

                if (result.code === 1) { 
                    
                    showCart();
                } else {
                    alert('Thông báo thất bại: ' + result.message);
                }
            } catch (error) {
                console.error('Đã xảy ra lỗi:', error);
                alert('Không thể kết nối đến máy chủ');
            }
        }
        /**
         * Khởi tạo các sự kiện khi trang đã sẵn sàng
         */
        document.addEventListener("DOMContentLoaded", function () {
            // Tải dữ liệu ban đầu
            doSearch(1);
            showCart();

            // Xử lý sự kiện submit Form tìm kiếm
            const formSearch = document.getElementById("formSearch");
            if (formSearch) {
                formSearch.addEventListener("submit", function (e) {
                    e.preventDefault();
                    doSearch(1);
                });
            }

            // Xử lý sự kiện Submit chung (Thêm vào giỏ và Lập đơn hàng)
            document.addEventListener("submit", function (e) {
                console.log(e.target);
                // 1. Thêm mặt hàng vào giỏ
                if (e.target.classList.contains("form-add-to-cart")) {
                    e.preventDefault();
                    const form = e.target;
                    addCartItem(form.ProductID.value, form.Quantity.value, form.price.value);
                }
                
                // 2. Lập đơn hàng (Xác nhận cuối cùng)
                if (e.target.id === "formOrder") {
                    e.preventDefault();
                    const form = e.target;
                    const action = form.getAttribute("action");
                    const formData = new FormData(form);

                    fetch(action, {
                        method: "POST",
                        body: formData
                    })
                    .then(res => res.json())
                    .then(result => {
                        if (result.code === 1) {
                            window.location.href = "/Order/Detail/" + result.message;
                        } else {
                            alert(result.message);
                        }
                    })
                    .catch(() => alert("Đã có lỗi xảy ra khi lập đơn hàng. Vui lòng kiểm tra lại thông tin."));
                }

                if (e.target.id === "formEditCartItem") {
                    e.preventDefault();
                    const form = e.target;
                    const action = form.getAttribute("action");
                    const formData = new FormData(form);

                    editCartItem(form.ProductID.value, form.Quantity.value, form.SalePrice.value);
                }
            });

            // Xử lý sự kiện Click chung (Xóa món, Xóa giỏ)
            document.addEventListener("click", function (e) {
                const ajaxBtn = e.target.closest(".ajax-remove, .ajax-clear");
                if (ajaxBtn) {
                    e.preventDefault();
                    const url = ajaxBtn.getAttribute("href");
                    
                    fetch(url)
                        .then(res => res.text())
                        .then(html => {
                            document.getElementById("cart-container").innerHTML = html;
                        })
                        .catch(err => console.error("Update cart error:", err));
                }
            });
        });
    </script>
}
