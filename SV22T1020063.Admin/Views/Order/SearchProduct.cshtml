@model PagedResult<Product>
@{
    Layout = null;
}
@if (Model.DataItems.Count > 0)
{
    @foreach (var item in Model.DataItems)
    {
        <form class="form-add-to-cart border rounded p-2 mb-2 bg-light">
            <input type="hidden" name="ProductID" value="@item.ProductID" />
            <input type="hidden" name="ProductName" value="@item.ProductName" />
            <input type="hidden" name="Photo" value="@item.Photo" />
            <input type="hidden" name="Unit" value="@item.Unit" />

            <div class="fw-bold text-truncate" title="@item.ProductName">@item.ProductName</div>

            <div class="row mt-2">
                <div class="col-4">
                    <img src="@(string.IsNullOrEmpty(item.Photo) ? "/images/products/demo.png" : "/images/products/" + item.Photo)"
                         class="img-fluid border rounded" style="max-height:80px; width: 100%; object-fit: contain;" />
                </div>
                <div class="col-8">
                    <div class="row g-2">
                        <div class="col-7">
                            <label class="form-label mb-0 small text-muted">Giá</label>
                            <input class="form-control form-control-sm money-input text-end"
                                   id="SalePrice"
                                   name="price"
                                   value="@item.Price" />
                        </div>
                        <div class="col-5">
                            <label class="form-label mb-0 small text-muted">SL</label>
                            <input type="number"
                                   name="Quantity"
                                   min="1"
                                   value="1"
                                   class="form-control form-control-sm text-center" />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-sm btn-primary mt-2 w-100">
                        <i class="bi bi-cart-plus"></i>
                        Thêm vào giỏ
                    </button>
                </div>
            </div>
        </form>
    }

    if (Model.PageCount > 1)
    {
        <ul class="pagination pagination-sm justify-content-between mb-0 mt-3">
            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                <a class="page-link" href="javascript:;" onclick="doSearch(@(Model.Page - 1))">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>
            <li class="page-item disabled">
                <span class="page-link">Trang @Model.Page / @Model.PageCount</span>
            </li>
            <li class="page-item @(Model.Page >= Model.PageCount ? "disabled" : "")">
                <a class="page-link" href="javascript:;" onclick="doSearch(@(Model.Page + 1))">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        </ul>
    }
}
else
{
    <div class="text-center py-4">
        <p class="text-muted">Không tìm thấy mặt hàng nào</p>
    </div>
}
