@{
    ViewBag.Title = "Cập nhật mặt hàng trong đơn hàng";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-6 mx-auto">
            <div class="card mb-3 shadow-sm">
                <div class="card-body d-flex justify-content-between align-items-center py-2">
                    <h4 class="m-0 fw-bold text-primary">Chỉnh sửa mặt hàng</h4>
                    <a href="/Order/Detail/10254" class="btn btn-secondary btn-sm">
                        <i class="bi bi-arrow-left"></i> Quay lại đơn hàng
                    </a>
                </div>
            </div>

            <div class="card card-outline card-primary shadow-sm">
                <div class="card-header">
                    <h3 class="card-title fw-bold">Thông tin thay đổi</h3>
                </div>

                <form action="/Order/UpdateCartItem" method="post">
                    <div class="card-body">
                        <table class="table table-sm table-borderless mb-4">
                            <tbody>
                                <tr class="border-bottom">
                                    <th class="py-2" style="width: 30%">Sản phẩm:</th>
                                    <td class="py-2 fw-bold text-dark">iPhone 15 Pro Max 256GB (Titanium)</td>
                                </tr>
                                <tr class="border-bottom">
                                    <th class="py-2">Giá niêm yết:</th>
                                    <td class="py-2 text-muted">34.000.000 ₫</td>
                                </tr>
                            </tbody>
                        </table>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="Quantity" class="form-label fw-bold">Số lượng</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-box-seam"></i></span>
                                    <input type="number" id="Quantity" name="Quantity" class="form-control"
                                           value="1" min="1" required>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label for="SalePrice" class="form-label fw-bold">Giá bán (Thỏa thuận)</label>
                                <div class="input-group">
                                    <input type="text" id="SalePrice" name="SalePrice" class="form-control text-end fw-bold text-danger"
                                           value="32.990.000">
                                    <span class="input-group-text bg-light">₫</span>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4 p-3 bg-light rounded border">
                            <div class="d-flex">
                                <i class="bi bi-info-circle text-primary me-2"></i>
                                <small class="text-muted">
                                    Lưu ý: Việc thay đổi số lượng hoặc giá bán sẽ trực tiếp làm thay đổi <strong>Tổng giá trị đơn hàng</strong>. Hãy kiểm tra kỹ trước khi lưu.
                                </small>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer bg-transparent d-flex justify-content-end gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-floppy-fill me-1"></i> Lưu thay đổi
                        </button>
                        <a href="/Order/Detail/10254" class="btn btn-outline-secondary">
                            Hủy bỏ
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>