@{
    ViewBag.Title = "Chi tiết đơn hàng";
}

<div class="container-fluid">
    <div class="card mb-3 shadow-sm">
        <div class="card-body d-flex justify-content-between align-items-center py-2">
            <div>
                <h4 class="m-0 fw-bold text-primary">Đơn hàng: #10254</h4>
            </div>
            <div class="d-flex gap-2">
                <div class="dropdown">
                    <button class="btn btn-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-gear-fill me-1"></i> Xử lý đơn hàng
                    </button>
                    <ul class="dropdown-menu shadow">
                        <li><a class="dropdown-item" href="/Order/Accept/10254"><i class="bi bi-check-circle text-success me-2"></i>Duyệt đơn hàng</a></li>
                        <li><a class="dropdown-item" href="/Order/Shipping/10254"><i class="bi bi-truck text-info me-2"></i>Xác nhận giao hàng</a></li>
                        <li><a class="dropdown-item" href="/Order/Finish/10254"><i class="bi bi-flag-fill text-primary me-2"></i>Xác nhận hoàn tất</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="/Order/Reject/10254"><i class="bi bi-x-circle text-warning me-2"></i>Từ chối đơn hàng</a></li>
                        <li><a class="dropdown-item" href="/Order/Cancel/10254 text-danger"><i class="bi bi-trash text-danger me-2"></i>Hủy đơn hàng</a></li>
                    </ul>
                </div>

                <a href="/Order/Delete/10254" class="btn btn-outline-danger" onclick="return confirm('Xác nhận xóa đơn hàng này?')">
                    <i class="bi bi-trash"></i> Xóa đơn
                </a>
                <a href="/Order" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card card-outline card-primary mb-4">
                <div class="card-header">
                    <h3 class="card-title fw-bold">Thông tin khách hàng</h3>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm table-borderless mb-0">
                        <tbody>
                            <tr class="border-bottom">
                                <th class="ps-3 py-2" style="width: 40%">Khách hàng:</th>
                                <td class="py-2">Nguyễn Thị Lan Anh</td>
                            </tr>
                            <tr class="border-bottom">
                                <th class="ps-3 py-2">Người lập đơn:</th>
                                <td class="py-2 text-primary">Trần Văn B (Nhân viên)</td>
                            </tr>
                            <tr class="border-bottom">
                                <th class="ps-3 py-2">Tỉnh/Thành:</th>
                                <td class="py-2"><span class="badge bg-info">Thừa Thiên Huế</span></td>
                            </tr>
                            <tr>
                                <th class="ps-3 py-2">Địa chỉ nhận:</th>
                                <td class="py-2">123 Hùng Vương, TP. Huế</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card card-outline card-info mb-4">
                <div class="card-header">
                    <h3 class="card-title fw-bold">Vận chuyển & Trạng thái</h3>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm table-borderless mb-0">
                        <tbody>
                            <tr class="border-bottom">
                                <th class="ps-3 py-2" style="width: 40%">Người giao:</th>
                                <td class="py-2 fw-bold text-info">Giao Hàng Nhanh (GHN)</td>
                            </tr>
                            <tr class="border-bottom">
                                <th class="ps-3 py-2">Trạng thái:</th>
                                <td class="py-2"><span class="badge rounded-pill text-bg-warning">Đang giao hàng</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card mb-4 shadow-sm border-0">
                <div class="card-body py-3">
                    <div class="row text-center">
                        <div class="col border-end">
                            <div class="small text-muted text-uppercase">Ngày lập</div>
                            <div class="fw-bold">03/03/2026 14:30</div>
                        </div>
                        <div class="col border-end">
                            <div class="small text-muted text-uppercase">Ngày duyệt</div>
                            <div class="fw-bold text-success">03/03/2026 15:00</div>
                        </div>
                        <div class="col border-end">
                            <div class="small text-muted text-uppercase">Ngày giao</div>
                            <div class="fw-bold text-info">04/03/2026 08:00</div>
                        </div>
                        <div class="col">
                            <div class="small text-muted text-uppercase">Hoàn tất</div>
                            <div class="text-muted italic">--/--/----</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card card-outline card-success">
                <div class="card-header">
                    <h3 class="card-title fw-bold">Danh sách mặt hàng</h3>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 50px" class="text-center">STT</th>
                                    <th>Tên sản phẩm</th>
                                    <th style="width: 80px" class="text-center">SL</th>
                                    <th class="text-end">Đơn giá</th>
                                    <th class="text-end" style="width: 150px">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="text-center">1</td>
                                    <td>iPhone 15 Pro Max 256GB (Titanium)</td>
                                    <td class="text-center">1</td>
                                    <td class="text-end">32.990.000 ₫</td>
                                    <td class="text-end fw-bold">32.990.000 ₫</td>
                                </tr>
                                <tr>
                                    <td class="text-center">2</td>
                                    <td>Ốp lưng MagSafe iPhone 15</td>
                                    <td class="text-center">2</td>
                                    <td class="text-end">1.500.000 ₫</td>
                                    <td class="text-end fw-bold">3.000.000 ₫</td>
                                </tr>
                            </tbody>
                            <tfoot>
                                <tr class="bg-light">
                                    <th colspan="4" class="text-end text-uppercase">Tổng giá trị đơn hàng:</th>
                                    <th class="text-end text-danger fs-5">35.990.000 ₫</th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>