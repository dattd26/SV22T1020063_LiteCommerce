@model OrderViewInfo
@{
    ViewBag.Title = "Chi tiết đơn hàng";
	var userData = User.GetUserData();
}

@section PageToolBar {
    <div class="btn-group">
        @if (Model.Status != OrderStatusEnum.Completed &&
                           Model.Status != OrderStatusEnum.Cancelled &&
                           Model.Status != OrderStatusEnum.Rejected)
        {
            <button type="button" class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown">
                <i class="bi bi-gear me-1"></i> Xử lý đơn hàng
            </button>
            <ul class="dropdown-menu">
                @if (Model.Status == OrderStatusEnum.New)
                {
                    <li><a class="dropdown-item open-modal" href="~/Order/Accept/@Model.OrderID">Duyệt đơn hàng</a></li>
                }
                @if (Model.Status == OrderStatusEnum.Accepted)
                {
                    <li><a class="dropdown-item open-modal" href="~/Order/Shipping/@Model.OrderID">Chuyển giao hàng</a></li>
                }
                @if (Model.Status == OrderStatusEnum.Shipping)
                {
                    <li><a class="dropdown-item open-modal" href="~/Order/Finish/@Model.OrderID">Hoàn tất đơn hàng</a></li>
                }
                <li>
                    <hr class="dropdown-divider">
                </li>
                @if (Model.Status == OrderStatusEnum.New ||
                                               Model.Status == OrderStatusEnum.Accepted)
                {
                    <li><a class="dropdown-item text-danger open-modal" href="~/Order/Cancel/@Model.OrderID">Hủy đơn hàng</a></li>
                }
                @if (Model.Status == OrderStatusEnum.New)
                {
                    <li><a class="dropdown-item text-danger open-modal" href="~/Order/Reject/@Model.OrderID">Từ chối đơn hàng</a>
                    </li>
                }
            </ul>
        }
    </div>

    @if (Model.Status == OrderStatusEnum.New ||
               Model.Status == OrderStatusEnum.Cancelled ||
               Model.Status == OrderStatusEnum.Rejected)
    {
        <a href="~/Order/Delete/@Model.OrderID" class="btn btn-danger ms-1 open-modal">
            <i class="bi bi-trash"></i> Xóa
        </a>
    }

    <a href="~/Order" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<!-- TRẠNG THÁI ĐƠN HÀNG -->
@{
    string alertClass = "alert-info";
    string statusText = "";
    DateTime? statusTime = null;

    switch (Model.Status)
    {
        case OrderStatusEnum.New:
            alertClass = "alert-secondary";
            statusText = "Đơn hàng mới - Chờ duyệt";
            statusTime = Model.OrderTime;
            break;
        case OrderStatusEnum.Accepted:
            alertClass = "alert-primary";
            statusText = "Đã duyệt - Đang chờ chuyển hàng";
            statusTime = Model.AcceptTime;
            break;
        case OrderStatusEnum.Shipping:
            alertClass = "alert-warning";
            statusText = "Đang giao hàng";
            statusTime = Model.ShippedTime;
            break;
        case OrderStatusEnum.Completed:
            alertClass = "alert-success";
            statusText = "Đã hoàn tất";
            statusTime = Model.FinishedTime;
            break;
        case OrderStatusEnum.Cancelled:
            alertClass = "alert-danger";
            statusText = "Đã hủy";
            statusTime = Model.FinishedTime;
            break;
        case OrderStatusEnum.Rejected:
            alertClass = "alert-danger";
            statusText = "Bị từ chối";
            statusTime = Model.FinishedTime;
            break;
    }
}

<div class="alert @alertClass d-flex align-items-center mb-3">
    <i class="bi bi-info-circle-fill fs-4 me-2"></i>
    <div>
        <strong>Trạng thái đơn hàng:</strong>
        @statusText @(statusTime.HasValue ? $"lúc {statusTime.Value:dd/MM/yyyy HH:mm}" : "")
    </div>
</div>

<!-- THÔNG TIN ĐƠN HÀNG -->
<div class="card card-primary card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-receipt me-2"></i> Thông tin đơn hàng
        </h5>
    </div>

    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Mã đơn hàng</div>
            <div class="col-md-3 text-primary fw-bold">@Model.OrderID</div>

            <div class="col-md-3 fw-bold">Ngày lập</div>
            <div class="col-md-3">@Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</div>
        </div>

        <div class="row">
            <div class="col-md-3 fw-bold">Nhân viên phụ trách</div>
            <div class="col-md-3">@userData.DisplayName</div>

            <div class="col-md-3 fw-bold">Ngày nhận đơn</div>
            <div class="col-md-3">@(Model.AcceptTime?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa nhận")</div>
        </div>
    </div>
</div>

<!-- THÔNG TIN KHÁCH HÀNG -->
<div class="card card-info card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-person me-2"></i> Thông tin khách hàng
        </h5>
    </div>

    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Khách hàng</div>
            <div class="col-md-3">@Model.CustomerName</div>

            <div class="col-md-3 fw-bold">Tên giao dịch</div>
            <div class="col-md-3">@Model.CustomerContactName</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Email</div>
            <div class="col-md-3">@Model.CustomerEmail</div>

            <div class="col-md-3 fw-bold">Điện thoại</div>
            <div class="col-md-3">@Model.CustomerPhone</div>
        </div>

        <div class="row">
            <div class="col-md-3 fw-bold">Địa chỉ</div>
            <div class="col-md-9">@Model.CustomerAddress</div>
        </div>
    </div>
</div>

<!-- THÔNG TIN GIAO HÀNG -->
<div class="card card-success card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-truck me-2"></i> Thông tin giao hàng
        </h5>
    </div>

    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Người giao hàng</div>
            <div class="col-md-3">@Model.ShipperName</div>

            <div class="col-md-3 fw-bold">Điện thoại</div>
            <div class="col-md-3">@Model.ShipperPhone</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Địa chỉ giao hàng</div>
            <div class="col-md-9">@Model.DeliveryAddress</div>
        </div>

        <div class="row">
            <div class="col-md-3 fw-bold">Tỉnh / Thành</div>
            <div class="col-md-9">@Model.DeliveryProvince</div>
        </div>
    </div>
</div>

<!-- DANH SÁCH MẶT HÀNG -->
<div class="card card-secondary card-outline">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-box-seam me-2"></i> Danh sách mặt hàng
        </h5>
    </div>

    <div class="card-body table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-secondary text-center">
                <tr>
                    <th>STT</th>
                    <th>Tên hàng</th>
                    <th>ĐVT</th>
                    <th>Số lượng</th>
                    <th>Giá</th>
                    <th>Thành tiền</th>
                    @if (Model.Status == OrderStatusEnum.New)
                    {
                        <th style="width:90px"></th>
                    }
                </tr>
            </thead>
            <tbody>
                @{
                    int i = 0;
                    decimal total = 0;
                }
                @foreach (var item in Model.Details)
                {
                    i++;
                    total += item.TotalPrice;
                    <tr>
                        <td class="text-center">@i</td>
                        <td>@item.ProductName</td>
                        <td class="text-center">@item.Unit</td>
                        <td class="text-center">@item.Quantity</td>
                        <td class="text-end">@item.SalePrice.ToString("N0")</td>
                        <td class="text-end">@item.TotalPrice.ToString("N0")</td>
                        @if (Model.Status == OrderStatusEnum.New)
                        {
                            <td class="text-end">
                                <a href="~/Order/EditCartItem/@Model.OrderID?productId=@item.ProductID"
                                       class="btn btn-sm btn-primary open-modal">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="~/Order/DeleteCartItem/@Model.OrderID?productId=@item.ProductID"
                                       class="btn btn-sm btn-danger open-modal">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        }
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="5" class="text-end">Tổng cộng</th>
                    <th class="text-end">@total.ToString("N0")</th>
                    @if (Model.Status == OrderStatusEnum.New)
                    {
                        <th></th>
                    }
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@section Styles {
    <style>
        .card-body .row {
            border-bottom: 1px dotted #646464;
        }
    </style>
}