@{
    ViewBag.Title = "Quản lý Đơn hàng";
}

<div class="container-fluid">
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <form action="/Order/Search" method="get">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Trạng thái đơn hàng</label>
                        <select class="form-select" name="status">
                            <option value="0">-- Tất cả trạng thái --</option>
                            <option value="1">Đơn hàng mới (Chờ duyệt)</option>
                            <option value="2">Đã duyệt (Chờ giao hàng)</option>
                            <option value="3">Đang giao hàng</option>
                            <option value="4">Đã hoàn tất</option>
                            <option value="-1">Đã hủy</option>
                            <option value="-2">Bị từ chối</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold">Thời gian lập đơn</label>
                        <div class="input-group">
                            <input type="date" name="fromDate" class="form-control" title="Từ ngày">
                            <span class="input-group-text">~</span>
                            <input type="date" name="toDate" class="form-control" title="Đến ngày">
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold">Tìm kiếm khách hàng/shipper</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input type="text" name="searchValue" class="form-control"
                                   placeholder="Tên khách hàng, địa chỉ hoặc người giao..." value="@Context.Request.Query["searchValue"]">
                        </div>
                    </div>

                    <div class="col-md-2 d-flex align-items-end">
                        <div class="btn-group w-100">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-filter"></i> Lọc
                            </button>
                            <a href="/Order" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-clockwise"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card card-outline card-primary">
        <div class="card-header d-flex align-items-center bg-transparent">
            <h3 class="card-title m-0 fw-bold text-primary">Danh sách đơn hàng</h3>
            <div class="ms-auto">
                <a href="/Order/Create" class="btn btn-success btn-sm">
                    <i class="bi bi-cart-plus me-1"></i> Lập đơn hàng mới
                </a>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-bordered mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 80px" class="text-center">Mã ĐH</th>
                            <th>Khách hàng</th>
                            <th class="text-center">Thời điểm lập</th>
                            <th>Nơi giao hàng</th>
                            <th>Người giao hàng</th>
                            <th class="text-center">Trạng thái</th>
                            <th style="width: 100px" class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @* Ví dụ hiển thị dữ liệu tĩnh *@
                        <tr>
                            <td class="text-center fw-bold">#10254</td>
                            <td>
                                <div class="fw-bold">Nguyễn Thị Lan Anh</div>
                                <div class="small text-muted"><i class="bi bi-person-badge me-1"></i>NV lập: Trần Văn B</div>
                            </td>
                            <td class="text-center">
                                <div>03/03/2026</div>
                                <div class="small text-muted">14:30:05</div>
                            </td>
                            <td>
                                <div class="badge bg-dark-subtle text-dark border border-dark-subtle mb-1">Thừa Thiên Huế</div>
                                <div class="small text-muted text-truncate" style="max-width: 200px;">123 Hùng Vương, TP. Huế</div>
                            </td>
                            <td>
                                <div class="fw-bold text-info">Giao Hàng Nhanh (GHN)</div>
                                <div class="small text-muted">Shipped: --/--/----</div>
                            </td>
                            <td class="text-center">
                                <span class="badge rounded-pill text-bg-primary">Đơn hàng mới</span>
                            </td>
                            <td class="text-center">
                                <a href="/Order/Detail/10254" class="btn btn-primary btn-sm" title="Xem chi tiết & Xử lý">
                                    <i class="bi bi-eye-fill"></i> Chi tiết
                                </a>
                            </td>
                        </tr>

                        <tr>
                            <td class="text-center fw-bold">#10250</td>
                            <td>
                                <div class="fw-bold">Công ty TNHH MTV ABC</div>
                                <div class="small text-muted"><i class="bi bi-person-badge me-1"></i>NV lập: Lê Thị C</div>
                            </td>
                            <td class="text-center">
                                <div>01/03/2026</div>
                                <div class="small text-muted">09:15:00</div>
                            </td>
                            <td>
                                <div class="badge bg-dark-subtle text-dark border border-dark-subtle mb-1">Đà Nẵng</div>
                                <div class="small text-muted text-truncate" style="max-width: 200px;">45 Nguyễn Văn Linh, Q. Hải Châu</div>
                            </td>
                            <td>
                                <div class="fw-bold text-info">Nguyễn Văn Shipper</div>
                                <div class="small text-muted">Shipped: 02/03/2026</div>
                            </td>
                            <td class="text-center">
                                <span class="badge rounded-pill text-bg-warning">Đang giao hàng</span>
                            </td>
                            <td class="text-center">
                                <a href="/Order/Detail/10250" class="btn btn-primary btn-sm">
                                    <i class="bi bi-eye-fill"></i> Chi tiết
                                </a>
                            </td>
                        </tr>

                        <tr>
                            <td class="text-center fw-bold">#10245</td>
                            <td>
                                <div class="fw-bold">Lê Hoàng Nam</div>
                                <div class="small text-muted">NV lập: Trần Văn B</div>
                            </td>
                            <td class="text-center">
                                25/02/2026
                            </td>
                            <td>
                                <div class="badge bg-dark-subtle text-dark border border-dark-subtle mb-1">Hà Nội</div>
                            </td>
                            <td>
                                <div class="fw-bold text-info">Viettel Post</div>
                            </td>
                            <td class="text-center">
                                <span class="badge rounded-pill text-bg-success">Đã hoàn tất</span>
                            </td>
                            <td class="text-center">
                                <a href="/Order/Detail/10245" class="btn btn-primary btn-sm">
                                    <i class="bi bi-eye-fill"></i> Chi tiết
                                </a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer bg-white d-flex align-items-center justify-content-between">
            <div class="text-muted small">
                Hiển thị <b>3</b> đơn hàng trong tổng số <b>150</b>
            </div>
            <nav>
                <ul class="pagination pagination-sm m-0">
                    <li class="page-item disabled"><a class="page-link" href="#"><i class="bi bi-chevron-left"></i></a></li>
                    <li class="page-item active"><a class="page-link" href="#">1</a></li>
                    <li class="page-item"><a class="page-link" href="#">2</a></li>
                    <li class="page-item"><a class="page-link" href="#">3</a></li>
                    <li class="page-item"><a class="page-link" href="#"><i class="bi bi-chevron-right"></i></a></li>
                </ul>
            </nav>
        </div>
    </div>
</div>