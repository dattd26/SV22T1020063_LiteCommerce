@model IEnumerable<OrderDetailViewInfo>
@{
    Layout = null;
    decimal total = 0;
    int i = 0;
}
<table class="table table-bordered table-hover align-middle mb-0">
    <thead class="table-success">
        <tr>
            <th class="text-center">#</th>
            <th style="width:auto">Tên hàng</th>
            <th class="text-center" style="width:80px">SL</th>
            <th class="text-end" style="width:120px">Giá</th>
            <th class="text-end" style="width:120px">Thành tiền</th>
            <th style="width:50px"></th>
            <th style="width:50px"></th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            @foreach (var item in Model)
            {
                total += item.TotalPrice;
                <tr>
                    <td class="text-center">@(++i)</td>
                    <td>
                        <div class="fw-bold">@item.ProductName</div>
                        @if (!string.IsNullOrEmpty(item.Unit))
                        {
                            <span class="badge bg-secondary">@item.Unit</span>
                        }
                    </td>
                    <td class="text-center">@item.Quantity</td>
                    <td class="text-end">@item.SalePrice.ToString("N0")</td>
                    <td class="text-end">@item.TotalPrice.ToString("N0")</td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-sm btn-primary open-modal"
                           href="~/Order/EditCartItem/@item.ProductID"
                           title="Cập nhật"
                           onclick="openModal(event, this)"
                           >
                            <i class="bi bi-pencil"></i>
                        </a>
                    </td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-sm btn-danger open-modal"
                           href="~/Order/DeleteCartItem/@item.ProductID"
                           title="Xóa"
                           onclick="openModal(event, this)"
                           >
                            <i class="bi bi-dash"></i>
                        </a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center py-4">
                    <p class="text-muted mb-0">Giỏ hàng trống</p>
                </td>
            </tr>
        }
    </tbody>
    @if (Model.Any())
    {
        <tfoot>
            <tr class="table-light">
                <th colspan="4" class="text-end">Tổng cộng:</th>
                <th class="text-end text-danger">@total.ToString("N0")</th>
                <th></th>
            </tr>
        </tfoot>
    }
</table>

@if (Model.Any())
{
    <div class="text-end mt-2">
        <a class="btn btn-sm btn-danger ajax-clear"
           href="~/Order/ClearCart">
            <i class="bi bi-trash"></i>
            Xóa giỏ hàng
        </a>
    </div>
}