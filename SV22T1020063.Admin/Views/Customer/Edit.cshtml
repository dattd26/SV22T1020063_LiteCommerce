
<div class="row">
    <div class="col-md-8 mx-auto w-100">
        <div class="card card-outline card-success">
            <div class="card-header">
                <h3 class="card-title">@ViewBag.Title</h3>
            </div>

            <form action="/Customer/Save" method="post">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-8 mb-3">
                            <label for="CustomerName" class="form-label fw-bold">Tên khách hàng</label>
                            <input type="text" class="form-control" id="CustomerName" name="CustomerName"
                                   placeholder="Ví dụ: Nguyễn Văn A" required>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label for="IsLocked" class="form-label fw-bold">Trạng thái</label>
                            <select class="form-select" id="IsLocked" name="IsLocked">
                                <option value="false">Đang hoạt động</option>
                                <option value="true">Bị khóa tài khoản</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="ContactName" class="form-label fw-bold">Tên giao dịch</label>
                            <input type="text" class="form-control" id="ContactName" name="ContactName"
                                   placeholder="Ví dụ: An Phat Corp">
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="Province" class="form-label fw-bold">Tỉnh/Thành</label>
                            <select class="form-select" id="Province" name="Province">
                                <option value="">-- Chọn Tỉnh/Thành --</option>
                                <option value="Hà Nội">Hà Nội</option>
                                <option value="Hồ Chí Minh">TP. Hồ Chí Minh</option>
                                <option value="Đà Nẵng">Đà Nẵng</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="Phone" class="form-label fw-bold">Điện thoại</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-telephone"></i></span>
                                <input type="tel" class="form-control" id="Phone" name="Phone" placeholder="09x.xxx.xxxx">
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label for="Email" class="form-label fw-bold">Email</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                <input type="email" class="form-control" id="Email" name="Email" placeholder="khachhang@example.com">
                            </div>
                        </div>

                        <div class="col-md-12 mb-3">
                            <label for="Address" class="form-label fw-bold">Địa chỉ cư trú</label>
                            <input type="text" class="form-control" id="Address" name="Address"
                                   placeholder="Số nhà, tên đường, phường/xã...">
                        </div>
                    </div>
                </div>

                <div class="card-footer d-flex justify-content-end gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-1"></i> Lưu dữ liệu
                    </button>
                    <a href="/Customer" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>