@using SV22T1020063.Models.Partner
@using SV22T1020063.Models.Common
@model PagedResult<Customer>

@{
    ViewBag.Title = "Quản lý Khách hàng";
}

@section PageToolBar {
    <a href="~/Customer/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}
<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch">
            <div class="input-group">
                <input type="text"
                       class="form-control"
                       placeholder="Tên khách hàng..."
                       name="searchValue"
                       value="@ViewBag.SearchValue"
                       autofocus />
                <button class="btn btn-info d-flex align-items-center">
                    <i class="bi bi-search me-1"></i>
                </button>
            </div>
        </form>
    </div>
</div>

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> khách hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th>Tên khách hàng</th>
                    <th>Tên giao dịch</th>
                    <th>Điện thoại</th>
                    <th>Email</th>
                    <th>Địa chỉ</th>
                    <th>Tỉnh / Thành</th>
                    <th class="text-center" style="width:120px;">Trạng thái</th>
                    <th class="text-center" style="width:100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DataItems)
                {
                    <tr>
                        <td>@item.CustomerName</td>
                        <td>@item.ContactName</td>
                        <td>@item.Phone</td>
                        <td>@item.Email</td>
                        <td>@item.Address</td>
                        <td>@item.Province</td>
                        <td class="text-center">
                            @if (!item.IsLocked)
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Không hoạt động</span>
                            }
                        </td>
                        <td class="text-center text-nowrap">
                            <a href="~/Customer/Edit/@item.CustomerID" class="btn btn-sm btn-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a href="~/Customer/Delete/@item.CustomerID" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                            <a href="~/Customer/ChangePassword/@item.CustomerID" class="btn btn-sm btn-warning ms-2">
                                <i class="bi bi-key"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer d-flex flex-column flex-md-row justify-content-between align-items-center bg-white py-3">
        <div class="text-muted mb-3 mb-md-0">
            @if (Model.RowCount > 0)
            {
                <span>Hiển thị từ <strong>@((Model.Page - 1) * Model.PageSize + 1)</strong> đến <strong>@(Math.Min(Model.Page * Model.PageSize, Model.RowCount))</strong> trong tổng số <strong>@Model.RowCount</strong> khách hàng</span>
            }
            else
            {
                <span>Không tìm thấy khách hàng nào phù hợp</span>
            }
        </div>

        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm mb-0 shadow-sm">
                @if (Model.PageCount > 1)
                {
                    <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                        <a class="page-link px-3" href="@Url.Action("Index", "Customer", new { page = 1, searchValue = ViewBag.SearchValue })" title="Trang đầu">
                            <i class="bi bi-chevron-bar-left"></i>
                        </a>
                    </li>
                    <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                        <a class="page-link px-3" href="@Url.Action("Index", "Customer", new { page = Model.Page - 1, searchValue = ViewBag.SearchValue })" title="Trang trước">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>

                    @foreach (var p in Model.GetDisplayPages())
                    {
                        if (p.IsEllipsis)
                        {
                            <li class="page-item disabled">
                                <span class="page-link">...</span>
                            </li>
                        }
                        else
                        {
                            <li class="page-item @(p.IsCurrent ? "active shadow-sm" : "")">
                                <a class="page-link px-3" href="@Url.Action("Index", "Customer", new { page = p.Page, searchValue = ViewBag.SearchValue })">@p.Page</a>
                            </li>
                        }
                    }

                    <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                        <a class="page-link px-3" href="@Url.Action("Index", "Customer", new { page = Model.Page + 1, searchValue = ViewBag.SearchValue })" title="Trang sau">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                    <li class="page-item @(Model.Page == Model.PageCount ? "disabled" : "")">
                        <a class="page-link px-3" href="@Url.Action("Index", "Customer", new { page = Model.PageCount, searchValue = ViewBag.SearchValue })" title="Trang cuối">
                            <i class="bi bi-chevron-bar-right"></i>
                        </a>
                    </li>
                }
            </ul>
        </nav>
    </div>
</div>

@section Styles {
    <style>
        .pagination .page-link {
            color: #495057;
            background-color: #fff;
            border: 1px solid #dee2e6;
            transition: all 0.2s ease-in-out;
            margin: 0 2px;
            border-radius: 4px !important;
        }

        .pagination .page-item.active .page-link {
            background-color: #0d6efd;
            border-color: #0d6efd;
            color: #fff;
            z-index: 3;
            font-weight: bold;
        }

        .pagination .page-item:not(.active):not(.disabled) .page-link:hover {
            background-color: #f8f9fa;
            color: #0d6efd;
            transform: translateY(-2px);
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .pagination .page-item.disabled .page-link {
            background-color: #f8f9fa;
            border-color: #dee2e6;
            color: #6c757d;
            opacity: 0.6;
        }

        .pagination .page-link:focus {
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
        }
    </style>
}
