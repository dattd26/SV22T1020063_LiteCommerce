@{
    ViewBag.Title = "Quản lý Khách hàng";
}

<div class="container-fluid">
    <div class="card mb-4">
        <div class="card-body">
            <form action="/Customer/Search" method="get" class="row g-3 align-items-center">
                <div class="col-md-10">
                    <div class="input-group">
                        <input type="text" name="searchValue" class="form-control"
                               placeholder="Nhập tên khách hàng, email hoặc số điện thoại..." aria-label="Search">
                        <button class="btn btn-primary" type="submit">
                            <i class="bi bi-search"></i> Tìm kiếm
                        </button>
                    </div>
                </div>
                <div class="col-md-2 text-md-end">
                    <a href="/Customer/Create" class="btn btn-success">
                        <i class="bi bi-plus-circle"></i> Thêm mới
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Danh sách khách hàng</h3>
            <div class="card-tools">
                <span class="badge text-bg-info">Tìm thấy 85 kết quả</span>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Tên khách hàng</th>
                            <th>Tên giao dịch</th>
                            <th>Điện thoại</th>
                            <th>Email</th>
                            <th>Địa chỉ</th>
                            <th>Tỉnh/Thành</th>
                            <th class="text-center">Trạng thái</th>
                            <th style="width: 120px" class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < 5; i++)
                        {
                            <tr>
                                <td>Nguyễn Văn A</td>
                                <td>An Phát Corp</td>
                                <td>0912345678</td>
                                <td>vana@gmail.com</td>
                                <td>45 Lương Thế Vinh</td>
                                <td>Hà Nội</td>
                                <td class="text-center">
                                    <span class="badge text-bg-success">Đang hoạt động</span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group">
                                        <a href="/Customer/Edit/2" class="btn btn-info btn-sm" title="Sửa">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a href="/Customer/Delete/2" class="btn btn-danger btn-sm" title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                        <a href="/Customer/ChangePassword/2" class="btn btn-warning btn-sm" title="Đổi mật khẩu">
                                            <i class="bi bi-key"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer clearfix">
            <nav aria-label="Page navigation example">
                <ul class="pagination pagination-sm m-0 justify-content-end">
                    <li class="page-item disabled"><a class="page-link" href="#">&laquo;</a></li>
                    <li class="page-item active"><a class="page-link" href="#">1</a></li>
                    <li class="page-item"><a class="page-link" href="#">2</a></li>
                    <li class="page-item"><a class="page-link" href="#">3</a></li>
                    <li class="page-item"><a class="page-link" href="#">&raquo;</a></li>
                </ul>
            </nav>
        </div>
    </div>
</div>