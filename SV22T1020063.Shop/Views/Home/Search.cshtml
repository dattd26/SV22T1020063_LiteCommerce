@model SV22T1020063.Models.Common.PagedResult<SV22T1020063.Models.Catalog.Product>
@{
    Layout = null;
}

<div class="flex items-center justify-between mb-12">
    <div>
        <h2 class="text-2xl font-black tracking-tight text-slate-900">
            @if (Model.RowCount > 0)
            {
                <span>Tất cả sản phẩm</span>
            }
            else
            {
                <span>Không tìm thấy sản phẩm</span>
            }
        </h2>
        <p class="text-xs font-medium text-slate-400 mt-1 uppercase tracking-widest">
            Showing @((Model.Page - 1) * Model.PageSize + 1) - @(Math.Min(Model.Page * Model.PageSize, Model.RowCount))
            of @Model.RowCount products
        </p>
    </div>
    <div class="flex items-center">
        <button
            class="inline-flex items-center text-xs font-bold uppercase tracking-widest text-slate-900 bg-gray-100 px-4 py-2 rounded-sm border border-transparent hover:border-gray-200">
            Sort: Featured
            <span class="material-symbols-outlined ml-2 text-lg">expand_more</span>
        </button>
    </div>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
    @foreach (var item in Model.DataItems)
    {
        <div
            class="group flex flex-col bg-white rounded-[2rem] overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300 border border-gray-100">
            
            <div class="relative aspect-square w-full bg-[#f3f4f6]">
                @if (string.IsNullOrEmpty(item.Photo))
                {
                    <img src="https://via.placeholder.com/400x400?text=No+Image" alt="@item.ProductName"
                         class="h-full w-full object-contain p-8 transition-transform duration-500 group-hover:scale-105">
                }
                else
                {
                    <img src="/images/products/@item.Photo" alt="@item.ProductName"
                         class="h-full w-full object-contain p-4 transition-transform duration-500 group-hover:scale-105">
                }

                @if (item.Price > 1000)
                {
                    <span
                        class="absolute top-4 left-4 bg-[#3f51b5] text-white text-[10px] font-bold uppercase px-4 py-1.5 rounded-full tracking-wider">
                        Featured
                    </span>
                }
            </div>

            <div class="p-6 flex flex-col flex-grow">
                <div class="mb-3">
                    <span
                        class="inline-block bg-[#e8f0fe] text-[#1a73e8] text-[11px] font-bold px-3 py-1 rounded-md uppercase">
                        @item.Unit
                    </span>
                </div>
                
                <h3 class="text-[15px] font-bold text-slate-900 leading-snug mb-6 flex-grow line-clamp-3">
                    @item.ProductName
                </h3>

                <div class="flex items-end justify-between mt-auto">
                    <div class="flex flex-col">
                        <span class="text-[10px] text-gray-400 font-bold uppercase mb-1">Giá bán</span>
                        <span class="text-xl font-black text-slate-900">
                            @item.Price.ToString("N0") <span class="underline decoration-1 underline-offset-2">đ</span>
                        </span>
                    </div>
                    
                    <button
                        class="h-11 w-11 rounded-full bg-[#2b4580] text-white flex items-center justify-center hover:bg-[#1e325c] transition-colors shadow-lg">
                        <span class="material-symbols-outlined text-xl">shopping_cart</span>
                    </button>
                </div>
            </div>
        </div>
    }
</div>

<!-- Pagination -->
@if (Model.PageCount > 1)
{
    <nav class="mt-24 flex items-center justify-center space-x-2">
        @if (Model.HasPreviousPage)
        {
            <button onclick="doSearch(@(Model.Page - 1))"
                    class="flex h-10 w-10 items-center justify-center rounded-sm bg-gray-50 text-slate-900 hover:bg-gray-100 transition-colors">
                <span class="material-symbols-outlined text-xl">chevron_left</span>
            </button>
        }

        @foreach (var p in Model.GetDisplayPages())
        {
            if (p.Page == 0)
            {
                <span class="text-slate-300">...</span>
            }
            else
            {
                if (p.Page == Model.Page)
                {
                    <button
                    class="flex h-10 w-10 items-center justify-center rounded-sm bg-indigo-700 text-xs font-bold text-white">@p.Page</button>
                }
                else
                {
                    <button onclick="doSearch(@p.Page)"
                            class="flex h-10 w-10 items-center justify-center rounded-sm bg-white text-xs font-bold text-slate-400 hover:bg-gray-50 transition-colors">@p.Page</button>
                }
            }
        }

        @if (Model.HasNextPage)
        {
            <button onclick="doSearch(@(Model.Page + 1))"
                    class="flex h-10 w-10 items-center justify-center rounded-sm bg-gray-50 text-slate-900 hover:bg-gray-100 transition-colors">
                <span class="material-symbols-outlined text-xl">chevron_right</span>
            </button>
        }
    </nav>
}
