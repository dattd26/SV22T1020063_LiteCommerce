                                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-lg font-semibold">Email</h3>
                        <p class="text-slate-500">lienhe@abc.com</p>
                    </div>
                </div>
            </div>

            <div class="relative h-64 w-full rounded-2xl overflow-hidden hover:grayscale-0 transition-all duration-500">
                <div class="mapouter">
