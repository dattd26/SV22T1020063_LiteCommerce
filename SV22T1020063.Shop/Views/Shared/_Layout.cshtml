<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SV22T1020063.Shop</title>
    <!-- Tailwind CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/flowbite/flowbite.min.css" asp-append-version="true" />
</head>

<body class="bg-gray-50 text-gray-900 font-sans antialiased flex flex-col min-h-screen">
    <header class="bg-white shadow">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex">
                    <div class="flex-shrink-0 flex items-center">
                        <a asp-area="" asp-controller="Home" asp-action="Index"
                            class="text-xl font-bold text-blue-600">LiteCommerce</a>
                    </div>
                </div>
                <div class="flex items-center space-x-4">
                    @if (User.Identity!.IsAuthenticated)







                    {
                        <div class="flex items-center space-x-3">
                            <a href="/Account/Profile"
                                class="text-sm font-medium text-gray-700 hover:text-blue-600 flex items-center">
                                <span
                                    class="bg-blue-100 text-blue-800 text-xs font-semibold mr-2 px-2.5 py-0.5 rounded dark:bg-blue-200 dark:text-blue-800">Khách
                                    hàng</span>
                                @User.FindFirst("DisplayName")?.Value
                            </a>
                            <a asp-area="" asp-controller="Account" asp-action="Logout"
                                class="text-gray-500 hover:text-red-600 text-sm font-medium transition-colors">Đăng xuất</a>
                        </div>
                    }

                    else

                    {
                        <a asp-area="" asp-controller="Account" asp-action="Login"
                            class="text-gray-700 hover:text-blue-600 font-medium">Đăng nhập</a>
                        <a asp-area="" asp-controller="Account" asp-action="Register"
                            class="text-gray-700 hover:text-blue-600 font-medium">Đăng ký</a>
                    }
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-grow container mx-auto px-4 sm:px-6 lg:px-8 py-8 w-full max-w-7xl">
        @RenderBody()
    </main>

    <footer class="bg-white border-t border-gray-200 mt-auto">
        <div class="max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8">
            <p class="text-center text-sm text-gray-500">
                &copy; 2026 - SV22T1020063.Shop - <a asp-area="" asp-controller="Home" asp-action="Privacy"
                    class="hover:text-blue-600">Privacy</a>
            </p>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/lib/flowbite/flowbite.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
