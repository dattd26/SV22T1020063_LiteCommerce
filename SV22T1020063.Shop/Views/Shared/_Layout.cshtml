<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SV22T1020063.Shop</title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
          rel="stylesheet">
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    
    <!-- Tailwind CSS & Flowbite -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/flowbite/flowbite.min.css" asp-append-version="true" />
    
    <style>
        /* Premium Animations */
        @@keyframes premium-fade-in {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .reveal-up {
            animation: premium-fade-in 1s cubic-bezier(0.19, 1, 0.22, 1) forwards;
        }

        /* Toast Styling Redesign */
        @@keyframes toast-premium-in {
            0% { transform: translateX(100%) skewX(-10deg); opacity: 0; }
            60% { transform: translateX(-15px) skewX(2deg); opacity: 1; }
            100% { transform: translateX(0) skewX(0); opacity: 1; }
        }

        @@keyframes toast-premium-out {
            0% { transform: translateX(0) skewX(0); opacity: 1; }
            100% { transform: translateX(120%) skewX(5deg); opacity: 0; }
        }

        .animate-toast-premium {
            animation: toast-premium-in 0.8s cubic-bezier(0.23, 1, 0.32, 1) forwards;
        }

        .animate-toast-premium-out {
            animation: toast-premium-out 0.8s cubic-bezier(0.23, 1, 0.32, 1) forwards;
        }

        .toast-progress-premium {
            position: absolute;
            bottom: 0;
            left: 0;
            height: 2px;
            background-color: #4f46e5; /* indigo-600 */
            width: 100%;
            transform-origin: left;
            animation: toast-progress-line 5s linear forwards;
        }

        @@keyframes toast-progress-line {
            from { transform: scaleX(1); }
            to { transform: scaleX(0); }
        }
    </style>
</head>

<body class="bg-[#f8f9fa] text-slate-900 font-sans antialiased flex flex-col min-h-screen">
    <partial name="_Header" />

    <main role="main" class="flex-grow">
        @RenderBody()
    </main>

    <partial name="_Footer" />
    
    <!-- Back to Top Button -->
    <button id="back-to-top"
            class="fixed bottom-8 right-8 z-[60] flex h-12 w-12 items-center justify-center rounded-full bg-indigo-600 text-white shadow-2xl transition-all duration-300 opacity-0 translate-y-10 hover:bg-indigo-700 hover:scale-110 active:scale-95 invisible">
        <span class="material-symbols-outlined text-2xl">arrow_upward</span>
    </button>

    <!-- Toast Container -->
    <div id="toast-container" class="fixed top-24 right-8 z-[100] flex flex-col gap-4 pointer-events-none"></div>

    <!-- Cart Container -->
    <div id="cart-container"></div>
    
    <!-- Confirm Modal -->
    <partial name="_ConfirmModal" />

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/lib/flowbite/flowbite.min.js"></script>
    <script>
            $(window).scroll(function () {
                if ($(this).scrollTop() > 300) {
                    $('#back-to-top').removeClass('opacity-0 translate-y-10 invisible').addClass('opacity-100 translate-y-0 visible');
                } else {
                    $('#back-to-top').addClass('opacity-0 translate-y-10 invisible').removeClass('opacity-100 translate-y-0 visible');
                }
            });

            $('#back-to-top').click(function () {
                window.scrollTo({ top: 0, behavior: 'smooth' });
            });

            const modalApp = {
                callback: null,
                show: function (title, message, onConfirm) {
                    document.getElementById('confirm-title').innerText = title;
                    document.getElementById('confirm-message').innerText = message;
                    this.callback = onConfirm;

                    const modal = document.getElementById('confirm-modal');
                    const content = modal.querySelector('.relative');

                    modal.classList.remove('opacity-0', 'pointer-events-none');
                    content.classList.remove('scale-95', 'opacity-0');
                    content.classList.add('scale-100', 'opacity-100');
                    document.body.classList.add('overflow-hidden');
                },
                close: function () {
                    const modal = document.getElementById('confirm-modal');
                    const content = modal.querySelector('.relative');

                    modal.classList.add('opacity-0', 'pointer-events-none');
                    content.classList.remove('scale-100', 'opacity-100');
                    content.classList.add('scale-95', 'opacity-0');
                    if (!document.getElementById('cart-sidebar') || document.getElementById('cart-sidebar').classList.contains('translate-x-full')) {
                        document.body.classList.remove('overflow-hidden');
                    }
                },
                confirm: function () {
                    if (this.callback) this.callback();
                    this.close();
                }
            };

            const cartApp = {
                init: function () {
                    this.updateBadge();
                },
                toggleCart: function () {
                    const sidebar = document.getElementById('cart-sidebar');
                    const wasOpen = sidebar && !sidebar.classList.contains('translate-x-full');
                
                    fetch('/Order/GetCartSidebar')
                        .then(res => res.text())
                        .then(html => {
                            document.getElementById('cart-container').innerHTML = html;
                            if (wasOpen) {
                                const newSidebar = document.getElementById('cart-sidebar');
                                const newOverlay = document.getElementById('cart-overlay');
                                if (newSidebar && newOverlay) {
                                    // Apply open classes immediately to avoid animation jump
                                    newSidebar.classList.remove('translate-x-full', 'duration-500');
                                    newOverlay.classList.remove('opacity-0', 'pointer-events-none', 'duration-500');
                                    document.body.classList.add('overflow-hidden');
                                    // Restore original duration after a frame
                                    setTimeout(() => {
                                        newSidebar.classList.add('duration-500');
                                        newOverlay.classList.add('duration-500');
                                    }, 50);
                                }
                            } else {
                                this.openCart();
                            }
                        });
                },
                openCart: function () {
                    setTimeout(() => {
                        const overlay = document.getElementById('cart-overlay');
                        const sidebar = document.getElementById('cart-sidebar');
                        if (overlay && sidebar) {
                            overlay.classList.remove('opacity-0', 'pointer-events-none');
                            sidebar.classList.remove('translate-x-full');
                            document.body.classList.add('overflow-hidden');
                        }
                    }, 50);
                },
                closeCart: function () {
                    const overlay = document.getElementById('cart-overlay');
                    const sidebar = document.getElementById('cart-sidebar');
                    if (overlay && sidebar) {
                        overlay.classList.add('opacity-0', 'pointer-events-none');
                        sidebar.classList.add('translate-x-full');
                        document.body.classList.remove('overflow-hidden');
                    }
                },
                addToCart: function (productId, quantity = 1, price = 0) {
                    $.post('/Order/AddToCart', { productId, quantity, salePrice: price }, (res) => {
                        if (res.success) {
                            this.updateBadge(res.itemsCount);
                            this.showToast('Thành công', 'Sản phẩm đã được thêm vào giỏ hàng');
                        } else {
                            this.showToast('Thông báo', res.message || 'Không thể thêm vào giỏ hàng');
                        }
                    });
                },
                removeFromCart: function (productId) {
                    $.post('/Order/RemoveFromCart', { productId }, (res) => {
                        if (res.success) {
                            this.updateBadge(res.itemsCount);
                            this.toggleCart();
                        }
                    });
                },
                updateQuantity: function (productId, quantity) {
                    if (quantity < 1) {
                        this.removeFromCart(productId);
                        return;
                    }
                    $.post('/Order/UpdateQuantity', { productId, quantity }, (res) => {
                        if (res.success) {
                            this.updateBadge(res.itemsCount);
                            this.toggleCart();
                        }
                    });
                },
                clearCart: function () {
                    modalApp.show(
                        'Xóa giỏ hàng?', 
                        'Bạn có chắc chắn muốn xóa toàn bộ sản phẩm trong giỏ hàng? Hành động này không thể hoàn tác.',
                        () => {
                            $.post('/Order/ClearCart', {}, (res) => {
                                if (res.success) {
                                    this.updateBadge(0);
                                    this.toggleCart();
                                    this.showToast('Thành công', 'Giỏ hàng đã được làm trống');
                                }
                            });
                        }
                    );
                },
                updateBadge: function (count) {
                    const badge = document.getElementById('cart-badge-count');
                    if (!badge) return;
                
                    if (count !== undefined) {
                        badge.innerText = count;
                        badge.classList.add('scale-125');
                        setTimeout(() => badge.classList.remove('scale-125'), 300);
                    } else {
                        $.get('/Order/GetCartInfo', (res) => {
                            badge.innerText = res.itemsCount || 0;
                        });
                    }
                },
                showToast: function (title, message) {
                    const container = document.getElementById('toast-container');
                    const toast = document.createElement('div');
                    toast.className = 'animate-toast-premium pointer-events-auto cursor-pointer relative overflow-hidden bg-white/95 backdrop-blur-xl border-l-[4px] border-indigo-600 shadow-2xl shadow-indigo-100/30 p-5 rounded-r-2xl flex items-center gap-4 min-w-[340px] transition-all hover:scale-[1.02] active:scale-95';
                    
                    toast.innerHTML = `
                        <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-indigo-50 flex items-center justify-center text-indigo-600 shadow-sm">
                            <span class="material-symbols-outlined font-black text-[20px]">shopping_cart_checkout</span>
                        </div>
                        <div class="flex-grow pr-4">
                            <h4 class="text-[10px] font-black text-slate-400 uppercase tracking-[0.15em] mb-0.5">${title}</h4>
                            <p class="text-sm font-bold text-slate-800 leading-tight">${message}</p>
                        </div>
                        <div class="toast-progress-premium"></div>
                    `;

                    const dismissToast = () => {
                        if (toast.dataset.dismissed) return;
                        toast.dataset.dismissed = "true";
                        toast.classList.remove('animate-toast-premium');
                        toast.classList.add('animate-toast-premium-out');
                        setTimeout(() => toast.remove(), 800);
                    };

                    toast.onclick = dismissToast;
                    container.appendChild(toast);

                    // Auto-exit animation sau 4.2s
                    setTimeout(dismissToast, 4200);
                }
            };

            $(document).ready(() => {
                cartApp.init();
               
            });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
