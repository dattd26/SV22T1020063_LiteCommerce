<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SV22T1020063.Shop</title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    
    <!-- Tailwind CSS & Flowbite -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/flowbite/flowbite.min.css" asp-append-version="true" />
    
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>

<body class="bg-[#f8f9fa] text-slate-900 font-sans antialiased flex flex-col min-h-screen">
    <partial name="_Header" />

    <main role="main" class="flex-grow">
        @RenderBody()
    </main>

    <partial name="_Footer" />
    
    <!-- Back to Top Button -->
    <button id="back-to-top" 
            class="fixed bottom-8 right-8 z-[60] flex h-12 w-12 items-center justify-center rounded-full bg-indigo-600 text-white shadow-2xl transition-all duration-300 opacity-0 translate-y-10 hover:bg-indigo-700 hover:scale-110 active:scale-95 invisible">
        <span class="material-symbols-outlined text-2xl">arrow_upward</span>
    </button>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/lib/flowbite/flowbite.min.js"></script>
    <script>
        $(window).scroll(function() {
            if ($(this).scrollTop() > 300) {
                $('#back-to-top').removeClass('opacity-0 translate-y-10 invisible').addClass('opacity-100 translate-y-0 visible');
            } else {
                $('#back-to-top').addClass('opacity-0 translate-y-10 invisible').removeClass('opacity-100 translate-y-0 visible');
            }
        });

        $('#back-to-top').click(function() {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
