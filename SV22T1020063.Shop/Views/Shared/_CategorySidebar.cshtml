@functions {
    string GetCategoryIcon(string categoryName)
    {
        return categoryName.ToLower() switch
        {
            "may mặc" => "apparel",
            "mỹ phẩm" => "face",
            "điện tử" => "devices",
            "hàng gia dụng" => "home",
            "mẹ và em bé" => "child_care",
            "xe máy" => "motorcycle",
            "oto" => "directions_car",
            "đồ chơi - phụ kiện" => "toys",
            "bàn ghế - nội thất" => "chair",
            _ => "category"
        };
    }
}

<!-- Sidebar -->
<aside class="w-52 md:w-56 lg:w-64 md:h-fit space-y-6 lg:space-y-8 shrink-0">
    <!-- 1. Categories (Vertical) -->
    <div>
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-900">Danh mục</h2>
            <div class="h-px flex-1 bg-gray-50 ml-4"></div>
        </div>
        <nav class="flex flex-col gap-1">
            <a href="javascript:;" onclick="doSearch(1, 0)" data-category-id="0"
                   class="category-link active group relative flex items-center gap-2.5 px-3 py-1.5 rounded-lg text-slate-500 hover:bg-gray-50 hover:text-indigo-600 transition-all duration-200 [&.active]:bg-indigo-50 [&.active]:text-indigo-600">
                <span
                class="absolute left-0 top-1/2 -translate-y-1/2 w-1 h-1.5 rounded-r bg-indigo-600 opacity-0 group-[.active]:opacity-100 transition-all"></span>
                <span
                class="material-symbols-outlined text-[18px] opacity-40 group-hover:opacity-100 group-[.active]:opacity-100 transition-all">auto_awesome_motion</span>
                <span class="text-xs font-bold tracking-tight">Tất cả sản phẩm</span>
            </a>

            @foreach (var category in ViewBag.Categories)
            {
                <a href="javascript:;" onclick="doSearch(1, @category.CategoryID, '@category.CategoryName')"
                       data-category-id="@category.CategoryID"
                       class="category-link group relative flex items-center gap-2.5 px-3 py-1.5 rounded-lg text-slate-500 hover:bg-gray-50 hover:text-indigo-600 transition-all duration-200 [&.active]:bg-indigo-50 [&.active]:text-indigo-600">
                    <span
                    class="absolute left-0 top-1/2 -translate-y-1/2 w-1 h-1.5 rounded-r bg-indigo-600 opacity-0 group-[.active]:opacity-100 transition-all"></span>
                    <span
                    class="material-symbols-outlined text-[20px] opacity-40 group-hover:opacity-100 group-[.active]:opacity-100 transition-all">@GetCategoryIcon(category.CategoryName)</span>
                    <span class="text-xs font-bold tracking-tight">@category.CategoryName</span>
                </a>
            }
        </nav>
    </div>

    <!-- 2. Filters (Search + Price) -->
    <div>
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-900">Bộ lọc</h2>
            <div class="h-px flex-1 bg-gray-50 ml-4"></div>
        </div>
        <div class="bg-gray-50/30 p-3 rounded-2xl border border-gray-100/50 space-y-4">
            <!-- Search -->
            <div class="relative group">
                <span
                class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-[16px] text-slate-400 group-focus-within:text-indigo-600 transition-colors">search</span>
                <input type="text" id="search-input" placeholder="Tên sản phẩm..." value="@ViewBag.SearchValue"
                       onkeyup="if(event.keyCode == 13) doSearch(1)"
                       class="w-full pl-10 pr-3 py-2 bg-white border border-gray-100 rounded-xl text-[16px] font-bold text-slate-900 focus:border-indigo-600/30 focus:ring-2 focus:ring-indigo-600/10 transition-all placeholder:text-slate-300 placeholder:font-normal">
            </div>

            <!-- Price Range -->
            <div class="flex flex-col gap-3 w-full max-w-[280px]">
                <span class="text-sm font-bold text-slate-700 uppercase tracking-wider">Khoảng giá</span>

                <div class="space-y-2">
                    <div class="relative group">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 font-bold">đ</span>
                        <input type="text" id="min-price-input" placeholder="Giá từ"
                               class="w-full pl-8 pr-4 py-3 bg-white border border-gray-200 rounded-xl text-[16px] font-bold text-slate-900 outline-none focus:ring-2 focus:ring-indigo-600/20 focus:border-indigo-600 transition-all placeholder:font-normal placeholder:text-slate-300">
                    </div>

                    <div class="flex justify-center">
                        <svg class="w-4 h-4 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
                        </svg>
                    </div>

                    <div class="relative group">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 font-bold">đ</span>
                        <input type="text" id="max-price-input" placeholder="Đến giá"
                               class="w-full pl-8 pr-4 py-3 bg-white border border-gray-200 rounded-xl text-[16px] font-bold text-slate-900 outline-none focus:ring-2 focus:ring-indigo-600/20 focus:border-indigo-600 transition-all placeholder:font-normal placeholder:text-slate-300">
                    </div>
                </div>

                <button onclick="doSearch(1)"
                        class="w-full mt-2 py-3 bg-indigo-600 text-white font-bold rounded-xl hover:bg-indigo-700 active:scale-[0.98] transition-all shadow-lg shadow-indigo-200">
                    Áp dụng
                </button>
                <script>
                                    document.getElementById('max-price-input').addEventListener('keydown', function () {
                                        if (event.key == 'Enter') {
                                            doSearch(1);
                                        }
                                    });
                                    document.getElementById('search-input').addEventListener('keydown', function () {
                                        if (event.key == 'Enter') {
                                            doSearch(1);
                                        }
                                    });
                </script>
            </div>
        </div>

    </aside>
