<header class="sticky top-0 z-50 w-full border-b border-gray-200/50 bg-white/70 backdrop-blur-xl">
    <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <!-- Logo -->
        <div class="flex items-center">
            <a asp-controller="Home" asp-action="Index" class="text-xl font-extrabold tracking-tighter text-indigo-700">
                TDD Shop
            </a>
        </div>

        <!-- Navigation Links (Desktop) -->
        <nav class="hidden md:ml-8 md:flex md:space-x-8">
            <a asp-controller="Home" asp-action="Index"
                   class="text-sm font-semibold @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "text-indigo-600" : "text-slate-900") hover:text-indigo-600 transition-colors">Trang
                chủ</a>
                <a asp-controller="Product" asp-action="Index"
                       class="text-sm font-medium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "text-indigo-600" : "text-slate-500") hover:text-indigo-600 transition-colors">Sản
                    phẩm</a>
                    <a href="#" class="text-sm font-medium text-slate-500 hover:text-indigo-600 transition-colors">Tin tức</a>
                    <a href="#" class="text-sm font-medium text-slate-500 hover:text-indigo-600 transition-colors">Liên hệ</a>
                    <a href="#" class="text-sm font-medium text-slate-500 hover:text-indigo-600 transition-colors">Đơn hàng</a>
                </nav>

                <!-- Search and Actions -->
                <div class="flex items-center space-x-6">
                    <div class="relative hidden sm:block" id="search-box">
                        <input type="text" id="header-search" placeholder="Nhập sản phẩm cần tìm..." autocomplete="off"
                               class="w-64 rounded-sm border-gray-200 bg-gray-50 py-2 pl-4 pr-10 text-sm focus:border-indigo-500 focus:ring-indigo-500 transition-all" />
                        <span
                            class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 text-xl pointer-events-none">
                            search
                        </span>

                        <!-- Suggestions Dropdown -->
                        <div id="search-suggestions"
                             class="absolute top-full right-0 mt-3 w-[400px] overflow-hidden rounded-sm bg-white/90 backdrop-blur-xl shadow-2xl border border-gray-200 opacity-0 translate-y-2 scale-95 pointer-events-none transition-all duration-200 z-[100]">
                            <div id="suggestions-content" class="max-h-[480px] overflow-y-auto divide-y divide-gray-100">
                                <!-- Items will be rendered here -->
                            </div>
                        </div>
                    </div>

                    <script>
                                    document.addEventListener('DOMContentLoaded', function () {
                                        const searchInput = document.getElementById('header-search');
                                        const suggestionsBox = document.getElementById('search-suggestions');
                                        const suggestionsContent = document.getElementById('suggestions-content');
                                        let debounceTimer;
                                        let selectedIndex = -1;

                                        function closeSuggestions() {
                                            suggestionsBox.classList.add('opacity-0', 'translate-y-2', 'scale-95', 'pointer-events-none');
                                            selectedIndex = -1;
                                        }

                                        function openSuggestions() {
                                            suggestionsBox.classList.remove('opacity-0', 'translate-y-2', 'scale-95', 'pointer-events-none');
                                        }

                                        function updateSelection() {
                                            const items = suggestionsContent.querySelectorAll('.suggestion-item');
                                            items.forEach((item, index) => {
                                                if (index === selectedIndex) {
                                                    item.classList.add('bg-indigo-50');
                                                    item.scrollIntoView({ block: 'nearest' });
                                                } else {
                                                    item.classList.remove('bg-indigo-50');
                                                }
                                            });
                                        }

                                        searchInput.addEventListener('input', function () {
                                            const query = this.value.trim();
                                            clearTimeout(debounceTimer);

                                            if (query.length < 1) {
                                                closeSuggestions();
                                                return;
                                            }

                                            debounceTimer = setTimeout(() => {
                                                fetch(`/Product/Suggestions?searchValue=${encodeURIComponent(query)}`)
                                                    .then(res => res.json())
                                                    .then(data => {
                                                        if (data.length > 0) {
                                                            suggestionsContent.innerHTML = data.map((item, index) => `
                                                                            <a href="/Product/Index?searchValue=${encodeURIComponent(item.productName)}" 
                                                                                class="suggestion-item group flex items-center gap-4 p-4 hover:bg-gray-50 transition-colors">
                                                                                <div class="h-12 w-12 flex-shrink-0 overflow-hidden rounded-sm bg-gray-100">
                                                                                    <img src="/images/products/${item.photo}" class="h-full w-full object-cover">
                                                                                </div>
                                                                                <div class="flex flex-col">
                                                                                    <span class="text-xs font-bold text-slate-800 uppercase tracking-tight line-clamp-1">${item.productName}</span>
                                                                                    <span class="text-[10px] font-black text-indigo-600">${item.price.toLocaleString()} VNĐ</span>
                                                                                </div>
                                                                            </a>
                                                                        `).join('');

                                                            // Add "View all" link
                                                            suggestionsContent.innerHTML += `
                                                                            <a href="/Product/Index?searchValue=${encodeURIComponent(query)}" 
                                                                                class="block p-3 text-center text-[10px] font-black uppercase tracking-[0.2em] text-indigo-600 bg-gray-50 hover:bg-indigo-50 transition-all">
                                                                                Xem tất cả kết quả
                                                                            </a>
                                                                        `;

                                                            openSuggestions();
                                                            selectedIndex = -1;
                                                        } else {
                                                            suggestionsContent.innerHTML = `<div class="p-4 text-center text-xs font-bold text-slate-400 uppercase tracking-widest">Không tìm thấy sản phẩm</div>`;
                                                            openSuggestions();
                                                        }
                                                    });
                                            }, 300);
                                        });

                                        searchInput.addEventListener('keydown', function (e) {
                                            const items = suggestionsContent.querySelectorAll('.suggestion-item');

                                            if (e.key === 'ArrowDown') {
                                                e.preventDefault();
                                                selectedIndex = Math.min(selectedIndex + 1, items.length - 1);
                                                updateSelection();
                                            } else if (e.key === 'ArrowUp') {
                                                e.preventDefault();
                                                selectedIndex = Math.max(selectedIndex - 1, -1);
                                                updateSelection();
                                            } else if (e.key === 'Enter') {
                                                if (selectedIndex >= 0) {
                                                    e.preventDefault();
                                                    items[selectedIndex].click();
                                                } else {
                                                    window.location.href = `/Product/Index?searchValue=${encodeURIComponent(this.value)}`;
                                                }
                                            } else if (e.key === 'Escape') {
                                                closeSuggestions();
                                            }
                                        });

                                        document.addEventListener('click', function (e) {
                                            if (!document.getElementById('search-box').contains(e.target)) {
                                                closeSuggestions();
                                            }
                                        });
                                    });
                    </script>

                    <!-- Cart -->
                    <button id="cart-toggle-btn" onclick="cartApp.toggleCart()" class="relative flex items-center text-slate-700 hover:text-indigo-600 transition-colors">
                        <span class="material-symbols-outlined text-2xl">
                            shopping_bag
                        </span>
                        <span id="cart-badge-count"
                            class="absolute -right-2 -top-1 flex h-5 w-5 items-center justify-center rounded-full bg-indigo-600 text-[10px] font-bold text-white transition-transform duration-300">
                            0
                        </span>
                    </button>

                    <!-- User/Account -->
                    @if (User.Identity!.IsAuthenticated)
                    {
                        <div class="flex items-center space-x-3">
                            <a href="/Account/Profile"
                                   class="flex items-center text-slate-700 hover:text-indigo-600 transition-colors">
                                <span class="material-symbols-outlined text-2xl">
                                    account_circle
                                </span>
                            </a>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login"
                               class="flex items-center text-slate-700 hover:text-indigo-600 transition-colors">
                            <span class="material-symbols-outlined text-2xl">
                                account_circle
                            </span>
                        </a>
                    }

                    <!-- Mobile menu button -->
                    <button class="md:hidden text-slate-700">
                        <span class="material-symbols-outlined text-2xl">
                            menu
                        </span>
                    </button>
                </div>
            </div>
        </header>
