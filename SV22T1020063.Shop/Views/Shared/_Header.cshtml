<header class="sticky top-0 z-50 w-full border-b border-gray-200/50 bg-white/70 backdrop-blur-xl">
    <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <!-- Logo -->
        <div class="flex items-center">
            <a asp-controller="Home" asp-action="Index" class="text-xl font-extrabold tracking-tighter text-indigo-700">
                TDD Shop
            </a>
        </div>

        <!-- Navigation Links (Desktop) -->
        <nav class="hidden md:ml-8 md:flex md:space-x-8">
            <a asp-controller="Home" asp-action="Index" 
               class="text-sm font-semibold @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "text-indigo-600" : "text-slate-900") hover:text-indigo-600 transition-colors">Trang chủ</a>
            <a asp-controller="Product" asp-action="Index" 
               class="text-sm font-medium @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "text-indigo-600" : "text-slate-500") hover:text-indigo-600 transition-colors">Sản phẩm</a>
            <a href="#" class="text-sm font-medium text-slate-500 hover:text-indigo-600 transition-colors">Tin tức</a>
            <a href="#" class="text-sm font-medium text-slate-500 hover:text-indigo-600 transition-colors">Liên hệ</a>
            <a href="#" class="text-sm font-medium text-slate-500 hover:text-indigo-600 transition-colors">Đơn hàng</a>
        </nav>

        <!-- Search and Actions -->
        <div class="flex items-center space-x-6">
            <div class="relative hidden sm:block">
                <input type="text" placeholder="Search products..."
                    class="w-64 rounded-lg border-gray-200 bg-gray-50 py-2 pl-4 pr-10 text-sm focus:border-indigo-500 focus:ring-indigo-500 transition-all" />
                <span
                    class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 text-xl">
                    search
                </span>
            </div>

            <!-- Cart -->
            <button class="relative flex items-center text-slate-700 hover:text-indigo-600 transition-colors">
                <span class="material-symbols-outlined text-2xl">
                    shopping_bag
                </span>
                <span
                    class="absolute -right-2 -top-1 flex h-5 w-5 items-center justify-center rounded-full bg-indigo-600 text-[10px] font-bold text-white">
                    0
                </span>
            </button>

            <!-- User/Account -->
            @if (User.Identity!.IsAuthenticated)
            {
                <div class="flex items-center space-x-3">
                    <a href="/Account/Profile"
                        class="flex items-center text-slate-700 hover:text-indigo-600 transition-colors">
                        <span class="material-symbols-outlined text-2xl">
                            account_circle
                        </span>
                    </a>
                </div>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login"
                    class="flex items-center text-slate-700 hover:text-indigo-600 transition-colors">
                    <span class="material-symbols-outlined text-2xl">
                        account_circle
                    </span>
                </a>
            }

            <!-- Mobile menu button -->
            <button class="md:hidden text-slate-700">
                <span class="material-symbols-outlined text-2xl">
                    menu
                </span>
            </button>
        </div>
    </div>
</header>
