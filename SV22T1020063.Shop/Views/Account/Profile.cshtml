@model SV22T1020063.Models.Partner.Customer
@{
    Layout = "_Layout";
    ViewData["Title"] = "Thông tin cá nhân";

    var initials = "U";
    if (!string.IsNullOrEmpty(Model.CustomerName))
    {
        var names = Model.CustomerName.Trim().Split(' ');
        if (names.Length > 1)
        {
            initials = $"{names[0][0]}{names[names.Length - 1][0]}".ToUpper();
        }
        else
        {
            initials = $"{names[0][0]}".ToUpper();
        }
    }
}
<div class="pt-8 pb-20 px-4 md:px-6 max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        <!-- Sidebar Navigation -->
        <aside class="lg:col-span-3 space-y-6 sticky top-24">
            <div
                class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex flex-col items-center text-center">
                <div
                    class="h-24 w-24 rounded-full bg-gradient-to-tr from-indigo-600 to-purple-600 flex items-center justify-center text-white font-black text-3xl shadow-xl shadow-indigo-100 mb-4 transition-transform hover:scale-105 duration-300">
                    @initials
                </div>
                <h2 class="font-black text-slate-800 text-xl tracking-tight">@Model.CustomerName</h2>
                <span
                    class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-black bg-indigo-50 text-indigo-600 uppercase tracking-widest mt-2">
                    <span class="w-1 h-1 rounded-full bg-indigo-600"></span>
                    Premium Member
                </span>
            </div>

            <nav class="space-y-1 bg-white p-2 rounded-2xl shadow-sm border border-slate-100">
                <button onclick="switchTab('profile')" id="nav-profile"
                        class="tab-nav-btn w-full flex items-center gap-3 px-4 py-3 bg-indigo-50 text-indigo-600 font-bold rounded-xl transition-all duration-300">
                    <span class="material-symbols-outlined font-bold">person</span>
                    <span class="text-sm">Thông tin cá nhân</span>
                </button>
                <button onclick="switchTab('settings')" id="nav-settings"
                        class="tab-nav-btn w-full flex items-center gap-3 px-4 py-3 text-slate-500 hover:bg-slate-50 font-bold rounded-xl transition-all duration-300">
                    <span class="material-symbols-outlined font-bold">settings</span>
                    <span class="text-sm">Thiết lập tài khoản</span>
                </button>
                <a class="flex items-center gap-3 px-4 py-3 text-slate-500 hover:bg-slate-50 font-bold rounded-xl transition-all duration-300"
                       href="/Order/Index">
                    <span class="material-symbols-outlined font-bold">history</span>
                    <span class="text-sm">Lịch sử đơn hàng</span>
                </a>
                <div class="pt-2 border-t border-slate-50 mt-2">
                    <a class="flex items-center gap-3 px-4 py-3 text-rose-500 hover:bg-rose-50 font-bold rounded-xl transition-all duration-300"
                           href="/Account/Logout">
                        <span class="material-symbols-outlined font-bold">logout</span>
                        <span class="text-sm">Đăng xuất</span>
                    </a>
                </div>
            </nav>
        </aside>

        <!-- Content Area -->
        <div class="lg:col-span-9">
            <!-- Messages -->
            @if (ViewBag.Message != null)
            {
                <div
                    class="flex items-center gap-3 p-4 mb-6 text-emerald-700 rounded-2xl bg-emerald-50 border border-emerald-100 animate-in fade-in slide-in-from-top-4 duration-500">
                    <span class="material-symbols-outlined">check_circle</span>
                    <div class="text-sm font-bold">@ViewBag.Message</div>
                </div>
            }
            @if (!ViewData.ModelState.IsValid)
            {
                <div
                    class="flex items-center gap-3 p-4 mb-6 text-rose-700 rounded-2xl bg-rose-50 border border-rose-100 animate-in fade-in slide-in-from-top-4 duration-500">
                    <span class="material-symbols-outlined">error</span>
                    <div asp-validation-summary="All" class="text-sm font-bold"></div>
                </div>
            }

            <!-- Profile Tab Content -->
            <div id="tab-profile" class="tab-content space-y-8 animate-in fade-in duration-500">
                <section class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
                    <div class="px-8 py-8 border-b border-slate-50 bg-slate-50/30 flex justify-between items-center">
                        <div>
                            <h1 class="text-2xl font-black text-slate-800 tracking-tight">Hồ sơ của tôi</h1>
                            <p class="text-slate-500 text-sm mt-1">Quản lý thông tin cá nhân và cài đặt liên lạc của
                                bạn.</p>
                            </div>
                        </div>

                        <form action="/Account/Profile" method="POST" class="p-8">
                            @Html.AntiForgeryToken()
                            <input type="hidden" asp-for="CustomerID" />
                            <input type="hidden" asp-for="Password" />

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6 mb-10">
                                <div class="space-y-2">
                                    <label class="text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Tên
                                        khách hàng</label>
                                        <input asp-for="CustomerName"
                                               class="w-full bg-slate-50 border-none rounded-xl px-4 py-3.5 text-slate-800 font-bold focus:ring-2 focus:ring-indigo-500/20 transition-all"
                                               required />
                                    </div>
                                    <div class="space-y-2">
                                        <label class="text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Tên liên
                                            hệ</label>
                                            <input asp-for="ContactName"
                                                   class="w-full bg-slate-50 border-none rounded-xl px-4 py-3.5 text-slate-800 font-bold focus:ring-2 focus:ring-indigo-500/20 transition-all"
                                                   required />
                                        </div>
                                        <div class="space-y-2">
                                            <label
                                            class="text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Email</label>
                                            <input asp-for="Email"
                                                   class="w-full bg-slate-50 border-none rounded-xl px-4 py-3.5 text-slate-800 font-bold focus:ring-2 focus:ring-indigo-500/20 transition-all"
                                                   type="email" required />
                                        </div>
                                        <div class="space-y-2">
                                            <label class="text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Số điện
                                                thoại</label>
                                                <input asp-for="Phone"
                                                       class="w-full bg-slate-50 border-none rounded-xl px-4 py-3.5 text-slate-800 font-bold focus:ring-2 focus:ring-indigo-500/20 transition-all"
                                                       type="tel" />
                                            </div>
                                            <div class="space-y-2">
                                                <label class="text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Tỉnh /
                                                    Thành phố</label>
                                                    <select asp-for="Province" asp-items="await SelectListHelper.ProvincesAsync()"
                                                            class="w-full bg-slate-50 border-none rounded-xl px-4 py-3.5 text-slate-800 font-bold focus:ring-2 focus:ring-indigo-500/20 transition-all appearance-none cursor-pointer">
                                                    </select>
                                                </div>
                                                <div class="md:col-span-2 space-y-2">
                                                    <label class="text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Địa chỉ
                                                        chi tiết</label>
                                                        <input asp-for="Address"
                                                               class="w-full bg-slate-50 border-none rounded-xl px-4 py-3.5 text-slate-800 font-bold focus:ring-2 focus:ring-indigo-500/20 transition-all"
                                                               type="text" />
                                                    </div>
                                                </div>

                                                <div class="flex justify-end gap-3">
                                                    <button type="reset"
                                                            class="px-6 py-3 text-sm font-bold text-slate-400 hover:text-slate-600 transition-all">Hủy
                                                        bỏ</button>
                                                        <button type="submit"
                                                                class="px-10 py-3 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-black uppercase tracking-widest rounded-xl shadow-lg shadow-indigo-100 transition-all active:scale-95">Lưu
                                                            thay đổi</button>
                                                        </div>
                                                    </form>
                                                </section>

                                                <!-- Stats -->
                                                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                                                    <div
                                                        class="bg-indigo-600 rounded-3xl p-8 text-white shadow-xl shadow-indigo-100 relative overflow-hidden group">
                                                        <div
                                                            class="absolute -right-4 -top-4 bg-white/10 w-24 h-24 rounded-full blur-2xl group-hover:bg-white/20 transition-all">
                                                        </div>
                                                        <span class="material-symbols-outlined text-4xl opacity-50 mb-4 block">shopping_bag</span>
                                                        <div class="relative z-10">
                                                            <span class="text-4xl font-black block">@ViewBag.TotalOrders</span>
                                                            <span class="text-xs font-bold uppercase tracking-widest opacity-70">Tổng đơn hàng</span>
                                                        </div>
                                                    </div>
                                                    <div
                                                        class="bg-white rounded-3xl p-8 border border-slate-100 shadow-sm relative overflow-hidden group">
                                                        <span
                                                        class="material-symbols-outlined text-4xl text-indigo-600 opacity-20 mb-4 block group-hover:rotate-12 transition-transform">star</span>
                                                        <span class="text-4xl font-black block text-slate-800">9999</span>
                                                        <span class="text-xs font-bold uppercase tracking-widest text-slate-400">Điểm tích lũy</span>
                                                    </div>
                                                    <div
                                                        class="bg-slate-900 rounded-3xl p-8 text-white shadow-xl shadow-slate-200 relative overflow-hidden group">
                                                        <span
                                                        class="material-symbols-outlined text-4xl text-emerald-400 mb-4 block">local_shipping</span>
                                                        <span class="text-4xl font-black block">@ViewBag.TotalShipping</span>
                                                        <span class="text-xs font-bold uppercase tracking-widest opacity-60">Đang giao hàng</span>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Settings Tab Content (Hidden by default) -->
                                            <div id="tab-settings" class="tab-content hidden space-y-8 animate-in fade-in duration-500">
                                                <section class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
                                                    <div class="px-8 py-8 border-b border-slate-50 bg-slate-50/30">
                                                        <h2 class="text-2xl font-black text-slate-800 tracking-tight">Thiết lập tài khoản</h2>
                                                        <p class="text-slate-500 text-sm mt-1">Quản lý mật khẩu và các tùy chọn bảo mật khác.</p>
                                                    </div>
                                                    <div class="p-8">
                                                        <div id="ajax-msg-container" class="hidden"></div>
                                                        <form action="/Account/ChangePassword" method="POST" class="space-y-8" id="frmChangePassword">
                                                            @Html.AntiForgeryToken()
                                                            <div class="grid grid-cols-1 gap-6 max-w-md">
                                                                <div class="space-y-2">
                                                                    <label class="text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Mật
                                                                        khẩu hiện tại</label>
                                                                        <div class="relative">
                                                                            <input name="oldPassword" id="oldPassword" autofocus
                                                                                   class="w-full bg-slate-50 border-none rounded-xl px-4 py-3.5 text-slate-800 font-bold focus:ring-2 focus:ring-indigo-500/20 transition-all pr-12"
                                                                                   type="password" required />
                                                                            <button type="button" onclick="togglePassword('oldPassword')" tabindex="-1"
                                                                                    class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-indigo-600 transition-colors">
                                                                                <span class="material-symbols-outlined text-xl">visibility</span>
                                                                            </button>
                                                                        </div>
                                                                    </div>
                                                                    <div class="space-y-2">
                                                                        <label class="text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Mật
                                                                            khẩu mới</label>
                                                                            <div class="relative">
                                                                                <input name="newPassword" id="newPassword"
                                                                                       class="w-full bg-slate-50 border-none rounded-xl px-4 py-3.5 text-slate-800 font-bold focus:ring-2 focus:ring-indigo-500/20 transition-all pr-12"
                                                                                       type="password" required />
                                                                                <button type="button" onclick="togglePassword('newPassword')" tabindex="-1"
                                                                                        class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-indigo-600 transition-colors">
                                                                                    <span class="material-symbols-outlined text-xl">visibility</span>
                                                                                </button>
                                                                            </div>
                                                                        </div>
                                                                        <div class="space-y-2">
                                                                            <label class="text-[11px] font-black text-slate-400 uppercase tracking-[0.2em]">Xác
                                                                                nhận mật khẩu mới</label>
                                                                                <div class="relative">
                                                                                    <input name="confirmPassword" id="confirmPassword"
                                                                                           class="w-full bg-slate-50 border-none rounded-xl px-4 py-3.5 text-slate-800 font-bold focus:ring-2 focus:ring-indigo-500/20 transition-all pr-12"
                                                                                           type="password" required />
                                                                                    <button type="button" onclick="togglePassword('confirmPassword')" tabindex="-1"
                                                                                            class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-indigo-600 transition-colors">
                                                                                        <span class="material-symbols-outlined text-xl">visibility</span>
                                                                                    </button>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                        <div class="pt-4 flex items-center justify-between border-t border-slate-50">
                                                                            <p class="text-xs text-slate-400 italic">* Mật khẩu nên bao gồm ít nhất 8 ký tự, bao gồm
                                                                                chữ cái và số.</p>
                                                                                <button type="submit"
                                                                                        class="px-10 py-3 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-black uppercase tracking-widest rounded-xl shadow-xl shadow-indigo-100 transition-all active:scale-95">
                                                                                    Cập nhật mật khẩu
                                                                                </button>
                                                                            </div>
                                                                        </form>
                                                                    </div>
                                                                </section>

                                                                <section
                                                                    class="bg-white rounded-3xl shadow-sm border border-slate-100 p-8 flex items-center justify-between group">
                                                                    <div class="flex items-center gap-4">
                                                                        <div
                                                                            class="w-12 h-12 rounded-2xl bg-rose-50 flex items-center justify-center text-rose-500 group-hover:scale-110 transition-transform">
                                                                            <span class="material-symbols-outlined text-3xl font-bold">no_accounts</span>
                                                                        </div>
                                                                        <div>
                                                                            <h3 class="font-black text-slate-800">Xóa tài khoản</h3>
                                                                            <p class="text-xs text-slate-500">Thao tác này không thể hoàn tác. Xin hãy cẩn trọng.</p>
                                                                        </div>
                                                                    </div>
                                                                    <button
                                                                        class="px-6 py-2 border-2 border-rose-100 text-rose-500 font-bold rounded-xl hover:bg-rose-50 hover:border-rose-200 transition-all">Yêu
                                                                        cầu xóa</button>
                                                                    </section>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    @section Scripts {
                                                        <script>
                                                            function switchTab(tabId) {
                                                                // Hide all contents
                                                                document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
                                                                // Remove active styles from all buttons
                                                                document.querySelectorAll('.tab-nav-btn').forEach(btn => {
                                                                    btn.classList.remove('bg-indigo-50', 'text-indigo-600');
                                                                    btn.classList.add('text-slate-500', 'hover:bg-slate-50');
                                                                });

                                                                // Show selected content
                                                                document.getElementById('tab-' + tabId).classList.remove('hidden');
                                                                // Add active styles to clicked button
                                                                const activeBtn = document.getElementById('nav-' + tabId);
                                                                activeBtn.classList.add('bg-indigo-50', 'text-indigo-600');
                                                                activeBtn.classList.remove('text-slate-500', 'hover:bg-slate-50');

                                                                // Save to hash for persistence on refresh (optional but recommended)
                                                                window.location.hash = tabId;

                                                                // Handle autofocus manually for hidden tabs
                                                                if (tabId === 'settings') {
                                                                    setTimeout(() => {
                                                                        document.getElementById('oldPassword')?.focus();
                                                                    }, 100);
                                                                }
                                                            }

                                                            function togglePassword(inputId) {
                                                                const input = document.getElementById(inputId);
                                                                const icon = input.nextElementSibling.querySelector('.material-symbols-outlined');
                                                                if (input.type === 'password') {
                                                                    input.type = 'text';
                                                                    icon.textContent = 'visibility_off';
                                                                } else {
                                                                    input.type = 'password';
                                                                    icon.textContent = 'visibility';
                                                                }
                                                            }

                                                            // Check hash on load
                                                            window.addEventListener('DOMContentLoaded', () => {
                                                                const hash = window.location.hash.replace('#', '');
                                                                if (hash === 'settings' || hash === 'profile') {
                                                                    switchTab(hash);
                                                                }
                                                            });

                                                            // Form handling for Change Password (AJAX)
                                                            $("#frmChangePassword").on("submit", function (e) {
                                                                e.preventDefault();
                                                                const $form = $(this);
                                                                const $btn = $form.find('button[type="submit"]');
                                                                const originalBtnText = $btn.html();
                                                                const $msgContainer = $("#ajax-msg-container");

                                                                // Disable button and show loading state
                                                                $btn.prop('disabled', true).html('<span class="inline-block animate-spin mr-2"></span> Đang xử lý...');

                                                                $.ajax({
                                                                    url: $form.attr('action'),
                                                                    type: 'POST',
                                                                    data: $form.serialize(),
                                                                    success: function (response) {
                                                                        $msgContainer.removeClass('hidden');
                                                                        if (response.success) {
                                                                            $msgContainer.html(`<div class="flex items-center gap-3 p-4 mb-6 text-emerald-700 rounded-2xl bg-emerald-50 border border-emerald-100"><span class="material-symbols-outlined">check_circle</span><div class="text-sm font-bold">${response.message}</div></div>`);
                                                                            $form[0].reset();
                                                                        } else {
                                                                            $msgContainer.html(`<div class="flex items-center gap-3 p-4 mb-6 text-rose-700 rounded-2xl bg-rose-50 border border-rose-100"><span class="material-symbols-outlined">error</span><div class="text-sm font-bold">${response.message}</div></div>`);
                                                                        }
                                                                    },
                                                                    error: function () {
                                                                        $msgContainer.removeClass('hidden').html('<div class="flex items-center gap-3 p-4 mb-6 text-rose-700 rounded-2xl bg-rose-50 border border-rose-100"><span class="material-symbols-outlined">error</span><div class="text-sm font-bold">Đã xảy ra lỗi hệ thống. Vui lòng thử lại sau.</div></div>');
                                                                    },
                                                                    complete: function () {
                                                                        $btn.prop('disabled', false).html(originalBtnText);
                                                                        // Scroll to message
                                                                        $msgContainer[0].scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                                                                    }
                                                                });
                                                            });
                                                        </script>
                                                    }
