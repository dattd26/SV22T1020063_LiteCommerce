@{
    Layout = "_Layout";
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="max-w-4xl mx-auto py-8">
    <div class="flex flex-col md:flex-row gap-8">
        <!-- Sidebar Navigation -->
        <aside class="w-full md:w-1/4">
            <div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden">
                <div class="px-6 py-4 bg-gray-50 border-bottom border-gray-100">
                    <p class="font-semibold text-gray-800">Tài khoản</p>
                </div>
                <nav class="flex flex-col">
                    <a href="/Account/Profile" class="px-6 py-3 text-sm font-medium text-gray-600 hover:bg-gray-50 hover:text-blue-600 transition-colors border-l-4 border-transparent">
                        Thông tin cá nhân
                    </a>
                    <a href="/Account/ChangePassword" class="px-6 py-3 text-sm font-medium bg-blue-50 text-blue-700 border-l-4 border-blue-600 transition-colors">
                        Đổi mật khẩu
                    </a>
                    <a href="/Order/Index" class="px-6 py-3 text-sm font-medium text-gray-600 hover:bg-gray-50 hover:text-blue-600 transition-colors">
                        Đơn hàng của tôi
                    </a>
                    <a href="/Account/Logout" class="px-6 py-3 text-sm font-medium text-red-600 hover:bg-red-50 transition-colors">
                        Đăng xuất
                    </a>
                </nav>
            </div>
        </aside>

        <!-- Main Content -->
        <div class="flex-grow bg-white rounded-lg shadow-sm border border-gray-100 p-6 md:p-8">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Thay đổi mật khẩu</h2>

            @if (ViewBag.Message != null)
            {
                <div id="alert-3" class="flex items-center p-4 mb-4 text-green-800 rounded-lg bg-green-50" role="alert">
                  <div class="ms-3 text-sm font-medium">
                    @ViewBag.Message
                  </div>
                  <button type="button" class="ms-auto -mx-1.5 -my-1.5 bg-green-50 text-green-500 rounded-lg focus:ring-2 focus:ring-green-400 p-1.5 hover:bg-green-200 inline-flex items-center justify-center h-8 w-8" data-dismiss-target="#alert-3" aria-label="Close">
                    <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                      <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
                    </svg>
                  </button>
                </div>
            }

            <div class="text-sm text-red-600 mb-4 font-medium">
                @Html.ValidationSummary(true)
            </div>

            <form action="/Account/ChangePassword" method="POST" class="space-y-6 max-w-md">
                @Html.AntiForgeryToken()
                <div>
                    <label for="oldPassword" class="block mb-2 text-sm font-medium text-gray-900">Mật khẩu cũ</label>
                    <input type="password" id="oldPassword" name="oldPassword" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5" required>
                    <span id="old-pass-error" class="text-red-600 text-xs mt-1">@Html.ValidationMessage("oldPassword")</span>
                </div>

                <div>
                    <label for="newPassword" class="block mb-2 text-sm font-medium text-gray-900">Mật khẩu mới</label>
                    <input type="password" id="newPassword" name="newPassword" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5" required minlength="4">
                    <span id="new-pass-error" class="text-red-600 text-xs mt-1">@Html.ValidationMessage("newPassword")</span>
                </div>

                <div>
                    <label for="confirmPassword" class="block mb-2 text-sm font-medium text-gray-900">Xác nhận mật khẩu mới</label>
                    <input type="password" id="confirmPassword" name="confirmPassword" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5" required>
                    <span id="confirm-pass-error" class="text-red-600 text-xs mt-1">@Html.ValidationMessage("confirmPassword")</span>
                </div>

                <div class="flex items-center gap-4">
                    <button type="submit" class="text-white bg-blue-600 hover:bg-blue-700 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-6 py-2.5 transition-colors">
                        Đổi mật khẩu
                    </button>
                    <a href="/Account/Profile" class="text-gray-900 bg-white border border-gray-300 focus:outline-none hover:bg-gray-100 focus:ring-4 focus:ring-gray-200 font-medium rounded-lg text-sm px-6 py-2.5 transition-colors">
                        Hủy bỏ
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
