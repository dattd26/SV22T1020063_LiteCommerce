@{
    ViewBag.Title = "Đặt hàng thành công | Digital Atelier";
}

<div class="bg-surface text-on-surface min-h-screen pt-32 pb-24">
    <div class="max-w-4xl mx-auto px-6 flex flex-col items-center text-center space-y-12">
        @{
            var breadcrumbs = new List<BreadcrumbItem>
            {
                new BreadcrumbItem { Text = "Thanh toán", Url = "/Order/Checkout" },
                new BreadcrumbItem { Text = "Hoàn tất", IsActive = true }
            };
        }
        <div class="w-full text-left">
            <partial name="_Breadcrumbs" model="breadcrumbs" />
        </div>
        <!-- Success Animation/Icon -->
        <div class="relative inline-block">
            <div class="absolute inset-0 bg-indigo-600 rounded-full blur-3xl opacity-20 animate-pulse"></div>
            <div
                class="relative w-24 h-24 bg-indigo-600 rounded-full flex items-center justify-center shadow-xl shadow-indigo-100">
                <span class="material-symbols-outlined text-5xl text-white">check_circle</span>
            </div>
        </div>

        <!-- Content -->
        <article class="space-y-6">
            <h1
                class="text-4xl md:text-5xl font-black tracking-tighter uppercase text-slate-800 dark:text-white leading-tight">
                ĐẶT HÀNG <br /> THÀNH CÔNG!
            </h1>
            
            <div class="h-1 w-24 bg-indigo-600 mx-auto rounded-full"></div>
            
            <p class="text-lg font-medium text-slate-500 max-w-md mx-auto leading-relaxed">
                Cảm ơn bạn đã tin tưởng mua sắm. Chúng tôi đã nhận được đơn hàng của bạn và sẽ liện hệ sớm nhất để xác
                nhận thông tin.
            </p>
        </article>

        <!-- Actions -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
            <a href="/Order"
                   class="px-8 py-4 bg-indigo-600 text-white font-black uppercase tracking-[0.2em] text-xs rounded-2xl shadow-lg shadow-indigo-100 hover:shadow-xl hover:bg-slate-900 transition-all active:scale-95 w-full sm:w-auto">
                Xem đơn hàng của tôi
            </a>
            <a href="/Product"
                   class="px-8 py-4 bg-surface-container-low text-on-surface-variant font-black uppercase tracking-[0.2em] text-xs rounded-2xl hover:bg-surface-container-high transition-all active:scale-95 w-full sm:w-auto">
                Tiếp tục mua hàng
            </a>
        </div>

        <footer class="pt-12 border-t border-slate-100 dark:border-slate-800">
            <p class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-300 dark:text-slate-600">
                Thank you ❤️
            </p>
        </footer>
    </div>
</div>
