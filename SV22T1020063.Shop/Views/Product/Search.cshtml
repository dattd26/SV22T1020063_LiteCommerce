@model SV22T1020063.Models.Common.PagedResult<SV22T1020063.Models.Catalog.Product>
@{
    Layout = null;
}

@if (!string.IsNullOrEmpty(ViewBag.SearchValue))
{
    <div class="mb-10 flex items-center justify-between border-b border-gray-100 pb-5">
        <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-indigo-50 text-indigo-600">
                <span class="material-symbols-outlined text-2xl font-bold">search</span>
            </div>
            <div>
                <h1 class="text-xs font-black uppercase tracking-[0.2em] text-slate-400 mb-1">Kết quả tìm kiếm</h1>
                <p class="text-lg font-bold text-slate-900">
                    Sản phẩm cho "<span class="text-indigo-600">@ViewBag.SearchValue</span>"
                </p>
            </div>
        </div>
        <a href="~/Product"
               class="group flex items-center gap-2 rounded-xl border border-gray-100 bg-white px-5 py-2.5 text-[10px] font-black uppercase tracking-widest text-slate-600 transition-all hover:border-indigo-600 hover:text-indigo-600 active:scale-95 shadow-sm">
            Xóa tìm kiếm
            <span class="material-symbols-outlined text-[16px] transition-transform group-hover:rotate-90">close</span>
        </a>
    </div>
}

<div class="flex items-center justify-between mb-12">
    <div>
        <h2 class="text-2xl font-black tracking-tight text-slate-900">
            @if (Model.RowCount > 0)
            {
                <span>@(string.IsNullOrEmpty(ViewBag.CategoryName) ? "Tất cả sản phẩm" : ViewBag.CategoryName)</span>
            }
            else
            {
                <span>Không tìm thấy sản phẩm nào của @(string.IsNullOrEmpty(ViewBag.CategoryName) ? "toàn bộ cửa hàng" :
                                                                                                                                                                                                                                                                                                                                                                                                                                 ViewBag.CategoryName)</span>
                }
            </h2>
            <p class="text-xs font-medium text-slate-400 mt-1 uppercase tracking-widest">
                Showing @((Model.Page - 1) * Model.PageSize + 1) - @(Math.Min(Model.Page * Model.PageSize, Model.RowCount))
                of @Model.RowCount products
            </p>
        </div>
        <div class="flex items-center">
            <button
                class="inline-flex items-center text-xs font-bold uppercase tracking-widest text-slate-900 bg-gray-100 px-4 py-2 rounded-sm border border-transparent hover:border-gray-200">
                Sort: Featured
                <span class="material-symbols-outlined ml-2 text-lg">expand_more</span>
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-5 gap-y-8">
        @foreach (var item in Model.DataItems)
        {
            <div
                class="group relative flex flex-col bg-white rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-xl border border-gray-100/60">
                <!-- Image Wrapper -->
                <div class="relative aspect-[4/5] overflow-hidden bg-[#f9fafb]">
                    @if (string.IsNullOrEmpty(item.Photo))
                    {
                        <img src="https://via.placeholder.com/400x400?text=No+Image" alt="@item.ProductName"
                             window.location.href='/Product/Detail/@item.ProductID' href="~/Product/Detail/@item.ProductID"
                             class="h-full w-full object-contain p-8 transition-transform duration-700 group-hover:scale-105 opacity-50 cursor-pointer">
                    }
                    else
                    {
                        <img src="/images/products/@item.Photo" alt="@item.ProductName"
                             onclick="window.location.href='/Product/Detail/@item.ProductID'"
                             class="h-full w-full object-contain p-5 transition-transform duration-700 group-hover:scale-105 mix-blend-multiply cursor-pointer">
                    }
                    
                    <!-- Hover Actions (Simplified) -->
                    <div
                        class="absolute inset-x-0 bottom-0 p-3 translate-y-full group-hover:translate-y-0 transition-transform duration-300 bg-gradient-to-t from-black/5 to-transparent flex justify-center">
                        <button onclick="cartApp.addToCart(@item.ProductID, 1, @item.Price)"
                                class="w-full bg-white/95 backdrop-blur-md text-slate-900 font-bold py-2 rounded-lg shadow-sm hover:bg-indigo-600 hover:text-white transition-all duration-200 flex items-center justify-center gap-1.5 active:scale-95">
                            <span class="material-symbols-outlined text-[16px]">shopping_bag</span>
                            <span class="text-[10px] uppercase tracking-widest">Thêm giỏ</span>
                        </button>
                    </div>

                    <!-- Badge (Smaller) -->
                    <div class="absolute top-2.5 left-2.5">
                        <span
                            class="bg-white/90 backdrop-blur-sm text-slate-800 text-[8px] font-black px-2 py-0.5 rounded-full uppercase tracking-widest shadow-sm border border-gray-100/50">
                            @item.Unit
                        </span>
                    </div>
                </div>

                <!-- Info Section (More compact) -->
                <div class="p-4 flex flex-col flex-grow">
                    <div class="flex items-center gap-1.5 mb-2">
                        <div class="h-0.5 w-4 rounded-full bg-indigo-600/30"></div>
                        <span class="text-[8px] font-bold text-gray-400 uppercase tracking-widest">TDD Shop</span>
                    </div>
                
                    <h3 onclick="window.location.href='/Product/Detail/@item.ProductID'"
                        class="text-[13px] font-bold text-slate-900 leading-snug mb-3 line-clamp-2 hover:text-indigo-600 transition-colors cursor-pointer">
                        @item.ProductName
                    </h3>

                    <div class="mt-auto pt-3 border-t border-gray-50 flex items-center justify-between">
                        <div class="flex flex-col">
                            <span class="text-[8px] text-gray-400 font-bold uppercase mb-0.5">Giá</span>
                            <span class="text-base font-black text-slate-900 tracking-tight">
                                @item.Price.ToString("N0")<span class="text-[9px] font-medium text-slate-400 ml-0.5">đ</span>
                            </span>
                        </div>
                    
                        <a href="~/Product/Detail/@item.ProductID"
                               class="h-8 w-8 rounded-lg bg-gray-50 text-slate-400 flex items-center justify-center transition-all duration-300 group-hover:bg-indigo-50 group-hover:text-indigo-600">
                            <span class="material-symbols-outlined text-[18px]">trending_flat</span>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (Model.PageCount > 1)
    {
        <nav class="mt-32 flex items-center justify-center gap-3">
            @if (Model.HasPreviousPage)
            {
                <button onclick="doSearch(@(Model.Page - 1))"
                        class="flex h-12 w-12 items-center justify-center rounded-2xl bg-white border border-gray-100 text-slate-900 hover:bg-slate-900 hover:text-white transition-all duration-300 shadow-sm active:scale-90">
                    <span class="material-symbols-outlined">chevron_left</span>
                </button>
            }

            <div class="flex items-center gap-1 bg-gray-50/50 p-1.5 rounded-[1.25rem] border border-gray-100 backdrop-blur-sm">
                @foreach (var p in Model.GetDisplayPages())
                {
                    if (p.Page == 0)
                    {
                        <span class="flex h-10 w-10 items-center justify-center text-gray-300 font-bold">···</span>
                    }
                    else
                    {
                        if (p.Page == Model.Page)
                        {
                            <button
                            class="flex h-10 w-10 items-center justify-center rounded-xl bg-indigo-600 text-sm font-black text-white shadow-lg shadow-indigo-100">@p.Page</button>
                        }
                        else
                        {
                            <button onclick="doSearch(@p.Page)"
                                    class="flex h-10 w-10 items-center justify-center rounded-xl text-sm font-bold text-slate-500 hover:bg-white hover:text-slate-900 hover:shadow-sm transition-all duration-200">@p.Page</button>
                        }
                    }
                }
            </div>

            @if (Model.HasNextPage)
            {
                <button onclick="doSearch(@(Model.Page + 1))"
                        class="flex h-12 w-12 items-center justify-center rounded-2xl bg-white border border-gray-100 text-slate-900 hover:bg-slate-900 hover:text-white transition-all duration-300 shadow-sm active:scale-90">
                    <span class="material-symbols-outlined">chevron_right</span>
                </button>
            }
        </nav>
    }
</div>